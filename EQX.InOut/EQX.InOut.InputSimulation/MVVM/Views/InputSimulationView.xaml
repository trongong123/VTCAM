<Window x:Class="EQX.InOut.InputSimulation.InputSimulationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cvt="clr-namespace:EQX.InOut.InputSimulation.Converters"
        xmlns:local="clr-namespace:EQX.InOut.InputSimulation"
        mc:Ignorable="d"
        Title="InputSimulationView"
        Height="675" Width="1200">

    <Window.Resources>
        <Style TargetType="Button"
            BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="50"/>
        </Style>

        <cvt:InputOutputListConverter x:Key="InputOutputListConverter" />
        <cvt:BooleanToFillOnOffConverter x:Key="BooleanToFillOnOffConverter"/>
    </Window.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <UniformGrid Rows="1">
            <Button Content="Set Inputs to Origin"
                    Width="120"
                    Command="{Binding SetOriginInputsCommand}"/>
            <Button Content="Set Inputs to Run"
                    Width="120"
                    Command="{Binding SetRunInputsCommand}"/>
            <Button Content="Reset Inputs"
                    Width="120"
                    Command="{Binding ResetInputsCommand}"/>
        </UniformGrid>

        <Grid Grid.Row="1"
              Margin=" 5 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>

            <Button Content="←"
                    Width="120"
                    Command="{Binding DataContext.BoardIndexDecrease, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}" />
            <TextBlock Text="{Binding SelectedBoardIndex, StringFormat='{}Input Board #{0}'}"
                        Grid.Column="1"
                        TextAlignment="Center"
                        FontWeight="Bold"
                        FontSize="18"
                        VerticalAlignment="Center" />
            <Button Content="→"
                    Width="120"
                    Command="{Binding BoardIndexIncrease}"
                    Grid.Column="2" />
        </Grid>
            
        <ItemsControl Grid.Row="2">
                <ItemsControl.ItemsSource>
                    <MultiBinding Converter="{StaticResource InputOutputListConverter}">
                        <Binding
                            Path="DataContext.Inputs"
                            RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=Window}" />
                        <Binding
                            Path="DataContext.SelectedBoardIndex"
                            RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=Window}" />
                    </MultiBinding>
                </ItemsControl.ItemsSource>

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto"
                                    SharedSizeGroup="InOutIndexColumn" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <Ellipse
                                Width="30"
                                Margin="5 0"
                                Height="30"
                                Fill="{Binding Value,Converter={StaticResource BooleanToFillOnOffConverter}}"
                                Stroke="LightGray"
                                StrokeThickness="1">
                            </Ellipse>
                            <TextBlock
                                Grid.Column="1"
                                FontWeight="Bold" FontSize="12"
                                Margin="5 0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Text="{Binding Id,StringFormat={}[{0}]}"/>
                            <Button
                                Content="{Binding Name}"
                                Command="{Binding DataContext.InputClickCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}"
                                CommandParameter="{Binding .}"
                                Grid.Column="2" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
    </Grid>
</Window>
