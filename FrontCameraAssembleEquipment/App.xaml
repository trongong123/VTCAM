<Application x:Class="FrontCameraAssembleEquipment.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             xmlns:view="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:controls="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
             xmlns:inout="clr-namespace:EQX.InOut;assembly=EQX.InOut"
             xmlns:uiCvt="clr-namespace:EQX.UI.Converters;assembly=EQX.UI"
             xmlns:cvt="clr-namespace:FrontCameraAssembleEquipment.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Generic.xaml"/>
                
                <ResourceDictionary Source="/EQX.UI;component/Resources/Themes/SamsungTheme.xaml"/>
                <ResourceDictionary Source="/EQX.UI;component/Generic.xaml"/>

                <ResourceDictionary Source="/EQX.UI;component/Resources/Language/KoreanLanguage.xaml" />
                <ResourceDictionary Source="/EQX.UI;component/Resources/Language/VietnameseLanguage.xaml" />
                <ResourceDictionary Source="/EQX.UI;component/Resources/Language/ChineseLanguage.xaml" />
                <ResourceDictionary Source="/EQX.UI;component/Resources/Language/EnglishLanguage.xaml" />

                <ResourceDictionary>
                    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
                    <cvt:BooleanToBackgroundUnitInitConverter x:Key="BooleanToBackgroundUnitInitConverter"/>
                    <uiCvt:CylinderButtonBrushConverter x:Key="CylinderButtonBrushConverter"/>
                    <cvt:InterfaceSignalOnOffBrushConverter x:Key="InterfaceSignalOnOffBrushConverter"/>
                    <cvt:ErrorLogCountSelectedToBackgroundConverter x:Key="ErrorLogCountSelectedToBackgroundConverter"/>
                    <cvt:TrayCellStatusToContentConverter x:Key="TrayCellStatusToContentConverter"/>
                    <cvt:ListManualToVisibilityConverter x:Key="ListManualToVisibilityConverter"/>
                    <cvt:NameToVisibilityConverter x:Key="NameToVisibilityConverter"/>
                    <cvt:BooleanToBrushesOutputValue x:Key="BooleanToBrushesOutputValue"/>
                    <cvt:ProcessAlarmWarningStatusToLabelContentConverter x:Key="ProcessAlarmWarningStatusToLabelContentConverter"/>
                    <cvt:ProcessAlarmWarningStatusToBackgroundConverter x:Key="ProcessAlarmWarningStatusToBackgroundConverter"/>
                    <cvt:MaterialTypeToImageConverter x:Key="MaterialTypeToImageConverter"/>
                    <cvt:MaterialStatusToVisibilityConverter x:Key="MaterialStatusToVisibilityConverter"/>
                    <cvt:DoorStatusToBrushConverter x:Key="DoorStatusToBrushConverter"/>
                    <cvt:BoolenToBrushesStartStopButton x:Key="BoolenToBrushesStartStopButton"/>
                    <cvt:BooleanToBrushesInterfaceFillConverter x:Key="BooleanToBrushesInterfaceFillConverter"/>
                    <cvt:BooleanNegationConverter x:Key="BooleanNegationConverter"/>
                    <cvt:MotionsToVisibilityConverter x:Key="MotionsToVisibilityConverter"/>
                    <cvt:StringToDoubleConverter x:Key="StringToDoubleConverter"/>
                    <cvt:CellStatusToImageConverter x:Key="CellStatusToImageConverter"/>
                    <cvt:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
                    <cvt:IdEnumDescriptionConverter x:Key="IdEnumDescriptionConverter"/>
                    <cvt:PosLineBoolenToStringConverter x:Key="PosLineBoolenToStringConverter"/>
                    <cvt:MaterialProcessStatusToBrushesBackgroundConverter x:Key="MaterialProcessStatusToBrushesBackgroundConverter"/>
                    <cvt:BooleanToStringTrayTypeNameConverter x:Key="BooleanToStringTrayTypeNameConverter"/>
                    <cvt:AxisNameStringToAxisCordinateTypeConverter x:Key="AxisNameStringToAxisCordinateTypeConverter"/>
                    <cvt:CylinderTypeToButtonNameConverter x:Key="CylinderTypeToButtonNameConverter"/>
                    <cvt:ProcessNameToDescriptionConverter x:Key="ProcessNameToDescriptionConverter"/>
                    <cvt:EnumRunModeToBrushConverter x:Key="EnumRunModeToBrushConverter"/>
                    <cvt:InOutListPageConverter x:Key="InOutListPageConverter"/>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
            
            <DataTemplate DataType="{x:Type vm:FooterViewModel}">
                <view:FooterView/>
            </DataTemplate>
        
            <DataTemplate DataType="{x:Type vm:HeaderViewModel}">
                <view:HeaderView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:NavigateMenuViewModel}">
                <view:NavigateMenuView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:InitDeinitViewModel}">
                <view:InitDeinitView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:AutoViewModel}">
                <view:AutoView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:IOMonitoringViewModel}">
                <view:IOMonitoringView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:DataViewModel}">
                <view:DataView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:ManualViewModel}">
                <view:ManualView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:TeachViewModel}">
                <view:TeachView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:LogViewModel}">
                <view:LogView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:OriginViewModel}">
                <view:OriginView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:InitializeViewModel}">
                <view:InitializeView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:InterfaceViewModel}">
                <view:InterfaceView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ProductionInfoViewModel}">
                <view:ProductionInfoView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <view:LoginView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:ErrorLogViewModel}">
                <view:ErrorLogView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:DevViewModel}">
                <view:DevView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:TraySupplierManualViewModel}">
                <view:TraySupplierManualView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TrayCamLoaderManualViewModel}">
                <view:TrayCamLoaderManualView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CamSpongeDetachManualViewModel}">
                <view:CamSpongeDetachManualView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VinylDetachManualViewModel}">
                <view:VinylDetachManualView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CamAssembleManualViewModel}">
                <view:CamAssembleManualView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ConveyorManualViewModel}">
                <view:ConveyorManualView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VisionManualViewModel}">
                <view:VisionManualView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type controls:CameraTypeSelectViewModel}">
                <controls:CameraTypeSelectView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type inout:CylinderBase}">
                <controls:CylinderControlView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
