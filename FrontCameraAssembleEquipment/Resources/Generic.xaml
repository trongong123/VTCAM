<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
                    xmlns:control="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
                    xmlns:inout="clr-namespace:EQX.InOut;assembly=EQX.InOut"
                    xmlns:dv="clr-namespace:FrontCameraAssembleEquipment.Defines"
                    xmlns:device="clr-namespace:EQX.Device.SpeedController;assembly=EQX.Device"
                    xmlns:devicebase="clr-namespace:EQX.Device.CognexDataMan150X;assembly=EQX.Device"
                    xmlns:vision="clr-namespace:FrontCameraAssembleEquipment.Vision">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Resources/Images/BitmapImageResources.xaml" />
        <ResourceDictionary Source="/Resources/Style/ActionButtonStyle.xaml" />
        <ResourceDictionary Source="/Resources/Style/CylinderControlStyle.xaml" />
        <ResourceDictionary Source="/Resources/Style/ConveyorControlStyle.xaml" />
        <ResourceDictionary Source="/Resources/Style/RadioButtonStyle.xaml" />
        <ResourceDictionary Source="/Resources/Style/CheckBoxButtonStyle.xaml" />
        <ResourceDictionary Source="/Resources/Style/DataGridCellStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    
    <DataTemplate DataType="{x:Type control:MaterialStatus}">
        <control:MaterialStatusView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type inout:ConveyorBase}">
        <control:CVControl/>
    </DataTemplate>
    
    <DataTemplate DataType="{x:Type dv:Vaccum}">
        <control:VaccumControl/>
    </DataTemplate>
    
    <DataTemplate DataType="{x:Type device:BD201SRollerController}">
        <control:RollerControl/>
    </DataTemplate>
    
    <DataTemplate DataType="{x:Type vision:VisionProcess}">
        <control:VisionControl/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type devicebase:BarCodeScannerBase}">
        <control:ReadBarcode/>
    </DataTemplate>

</ResourceDictionary>