<UserControl x:Class="FrontCameraAssembleEquipment.Resources.Controls.CameraTypeSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
             xmlns:defines="clr-namespace:FrontCameraAssembleEquipment.Defines"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=local:CameraTypeSelectViewModel}"
             d:DesignHeight="300" d:DesignWidth="180">

    <UserControl.Resources>
        <Style TargetType="RadioButton"
               BasedOn="{StaticResource ButtonLikeRadioButtonStyle}">
            <Style.Setters>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="3"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="GroupName" Value="CameraTypeGroupName"/>
            </Style.Setters>
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin"
            Value="3" />
            <Setter Property="Padding"
            Value="3" />
            <Setter Property="BorderThickness"
            Value="1" />
            <Setter Property="BorderBrush"
            Value="#DDD" />
            <Setter Property="Background"
            Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border CornerRadius="5"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        Background="White"
                        SnapsToDevicePixels="True">
                            <DockPanel>
                                <Border Background="#E1E1E2"
                                DockPanel.Dock="Top"
                                Padding="8,4"
                                CornerRadius="5,5,0,0">
                                    <TextBlock Text="{TemplateBinding Header}"
                                       FontWeight="SemiBold"
                                       Foreground="Black"
                                       VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                       FontSize="13" />
                                </Border>

                                <ContentPresenter />
                            </DockPanel>
                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <GroupBox Header="Region"
              FontSize="12">
        <UniformGrid Columns="1">
            <RadioButton Content="NAMUGA&#x0A;MCNEX"
                         FontSize="11"
                 Command="{Binding CameraTypeSelectedCommand}"
                 CommandParameter="{x:Static defines:ECameraType.NorM}">
                <RadioButton.Style>
                    <Style TargetType="{x:Type RadioButton}"
                   BasedOn="{StaticResource {x:Type RadioButton}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.CameraType, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Value="{x:Static defines:ECameraType.NorM}">
                                <Setter Property="Background" Value="SaddleBrown"/>
                                <Setter Property="Foreground" Value="WhiteSmoke"/>
                            </DataTrigger>
                        </Style.Triggers>
                        <Style.Setters>
                            <Setter Property="Foreground" Value="Black"/>
                        </Style.Setters>
                    </Style>
                </RadioButton.Style>
            </RadioButton>
            <RadioButton Content="CAMMSYS&#x0A;COASIA"
                         FontSize="11"
                 Command="{Binding CameraTypeSelectedCommand}"
                 CommandParameter="{x:Static defines:ECameraType.CorH}">
                <RadioButton.Style>
                    <Style TargetType="{x:Type RadioButton}"
                   BasedOn="{StaticResource {x:Type RadioButton}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.CameraType, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Value="{x:Static defines:ECameraType.CorH}">
                                <Setter Property="Background" Value="Yellow"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </RadioButton.Style>
            </RadioButton>
        </UniformGrid>
    </GroupBox>
</UserControl>
