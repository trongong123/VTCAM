<UserControl x:Class="FrontCameraAssembleEquipment.Resources.Controls.CVControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.Resources.Style"
             xmlns:inout="clr-namespace:EQX.InOut;assembly=EQX.InOut"
             xmlns:device="clr-namespace:FrontCameraAssembleEquipment.Defines"             
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type inout:ConveyorBase}}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="2">
            <Border.Resources>
                <Style x:Key="OverrideBtnStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Resources>
            <StackPanel Margin="5">
                <!--<TextBlock Text="[CV]" 
                            FontWeight="Bold" 
                            HorizontalAlignment="Center" 
                            Margin="0,0,0,5"/>-->
                <TextBlock Text="{Binding Name}" 
                            Visibility="{Binding Name, Converter={StaticResource NameToVisibilityConverter}}"
                            FontWeight="Bold" 
                            HorizontalAlignment="Center" 
                            Margin="0,0,0,5"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource ConveyorRunButtonStyle}"
                            Content="RUN"
                            Grid.Column="0"
                            Background="{Binding OutRunStatus, Converter={StaticResource BooleanToBrushesOutputValue}}" />
                    <Separator Width="35"
                               Height="1"
                               Margin="3 0"
                               Grid.Column="1">
                        <Separator.LayoutTransform>
                            <RotateTransform Angle="90" />
                        </Separator.LayoutTransform>
                    </Separator>
                    <Button Style="{StaticResource ConveyorStopButtonStyle}"
                            Content="STOP"
                            Grid.Column="2"
                            Background="{Binding OutStopStatus, Converter={StaticResource BooleanToBrushesOutputValue}}" />
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
