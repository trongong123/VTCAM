<Window x:Class="FrontCameraAssembleEquipment.Resources.Controls.UnitManualControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
        xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
        mc:Ignorable="d" 
        x:Name="root"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Height="600" Width="850">
    <Window.Resources>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#DDD" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border CornerRadius="5"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                Background="White"
                                SnapsToDevicePixels="True">
                            <DockPanel>
                                <Border Background="#E1E1E2"
                                        DockPanel.Dock="Top"
                                        Padding="8,4"
                                        CornerRadius="5,5,0,0">
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontWeight="SemiBold"
                                               Foreground="Black"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="13" />
                                </Border>

                                <ContentPresenter />
                            </DockPanel>
                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#C0C0C0" BorderThickness="1">
        <Grid Margin="0 0 0 5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>
            <!-- Header -->
            <Border Background="#E8E8E8" Height="40"
                    BorderBrush="Gray" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <TextBlock x:Name="ClockText" Text="{Binding Name}"
                       VerticalAlignment="Center"
                       FontWeight="Bold" FontSize="16"
                       Margin="10,0,0,0"/>
            </Border>

            <!--<ContentControl Grid.Row="1" Background="Tomato"/>-->
            <Grid Grid.Row="1" IsEnabled="{Binding MachineStatus.IsStandByProcessMode}">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="Cylinder">
                    <ItemsControl ItemsSource="{Binding Cylinders}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"
                                             Rows="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </GroupBox>
                <GroupBox Header="Conveyor"
                          Grid.Column="1">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Rollers}"
                                      Visibility="{Binding DevRecipe.IsUseRollerIOControl , Converter={StaticResource BooleanToVisibilityInvertConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CVs}"
                                      Visibility="{Binding DevRecipe.IsUseRollerIOControl , Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </GroupBox>
                <GroupBox Header="Function"
                          Grid.Row="1">
                    <Grid>
                        <ItemsControl ItemsSource="{Binding Vaccums}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"
                                                 Rows="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </GroupBox>
                <GroupBox Header="Position"
                          Grid.Row="1"
                          Grid.Column="1">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding TeachingPositions}" Margin="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Description}"
                                        Background="{Binding IsOnGroupPosition, Converter={StaticResource BooleanToBrushesOutputValue}}"
                                        FontSize="14" Margin="2"
                                        Command="{Binding DataContext.PositionMoveCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}"
                                        CommandParameter="{Binding .}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"
                                             VerticalAlignment="Top" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </GroupBox>
            </Grid>

            <GroupBox Grid.Row="1" Visibility="Collapsed">
                <GroupBox.Header>
                    <TextBlock Text="{Binding DataContext.Name,ElementName=root}"
                            HorizontalAlignment="Center"/>
                </GroupBox.Header>
                <DockPanel>
                    <WrapPanel DockPanel.Dock="Top" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ItemsControl ItemsSource="{Binding Rollers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}" Margin="1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding Cylinders}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <GroupBox Visibility="{Binding CVs,Converter={StaticResource ListManualToVisibilityConverter}}"
                              Header="Conveyors">
                            <ItemsControl ItemsSource="{Binding CVs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding .}" Margin="1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>
                        <ItemsControl ItemsSource="{Binding Vaccums}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}" Margin="1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                </DockPanel>
            </GroupBox>

           
            <!--</GroupBox>-->

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!--<GroupBox Grid.Row="2" Header="Material Edit" >-->
                <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsMaterialEditUse, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel.Resources>
                        <Style TargetType="{x:Type ui:ImageButton}"
                            BasedOn="{StaticResource {x:Type ui:ImageButton}}">
                            <Style.Setters>
                                <Setter Property="Padding" Value="5 10" />
                                <Setter Property="Margin" Value="3 0" />
                                <Setter Property="Width" Value="120" />
                                <Setter Property="FontSize" Value="13" />
                            </Style.Setters>
                        </Style>
                    </StackPanel.Resources>

                    <!--<Label Content="Material Status Edit: " FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>-->
                    <ui:ImageButton Content="Add" 
                        Image="{StaticResource image_plus_selected}"
                        Click="Add_Click"/>

                    <ui:ImageButton Content="Clear" 
                         Image="{StaticResource image_cancel_selected}"
                         Click="Clear_Click"/>
                </StackPanel>
                
                <UniformGrid Columns="1" Grid.Column="1"
                             Margin="3 0">
                    <Button FontSize="18"
                            Content="Initialize" Foreground="LightSkyBlue"
                            Command="{Binding InitializeCommand}"/>
                    <Button FontSize="18"
                            Content="Close" Foreground="Tomato"
                            Click="ExitButton_Click"/>
                </UniformGrid>
            </Grid>
            
        </Grid>
    </Border>
</Window>
