<Window x:Class="FrontCameraAssembleEquipment.Resources.Controls.RunModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
        xmlns:cvt="clr-namespace:EQX.UI.Converters;assembly=EQX.UI"
        xmlns:converter="clr-namespace:FrontCameraAssembleEquipment.Converters"
        xmlns:core="clr-namespace:EQX.Core.Process;assembly=EQX.Core"
        Title="Mode Select Viewer"
        xmlns:defines="clr-namespace:FrontCameraAssembleEquipment.Defines.Process"
        WindowStartupLocation="CenterOwner"
        xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
        xmlns:uiConverter="clr-namespace:EQX.UI.Converters;assembly=EQX.UI"
        WindowStyle="None"
        BorderBrush="Black"
        BorderThickness="2"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Window.Resources>
        <cvt:EnumToStringConverter x:Key="EnumToStringConverter"/>
        <uiConverter:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
        <Style TargetType="{x:Type ui:ImageButton}"
               BasedOn="{StaticResource {x:Type ui:ImageButton}}">
            <Style.Setters>
                <Setter Property="Padding" Value="5 10" />
                <Setter Property="Margin" Value="2" />
                <Setter Property="Height" Value="50" />
                <Setter Property="Width" Value="105" />
                <Setter Property="FontSize" Value="13" />
            </Style.Setters>
        </Style>

    </Window.Resources>
    <Border Padding="20">
        <Grid>
            <DockPanel>
                <Label Content="Select Run Mode" HorizontalAlignment="Left" FontWeight="Bold" FontSize="13"/>
                
                <ui:ImageButton DockPanel.Dock="Right" Content="Exit"
                    HorizontalAlignment="Right"
                                Margin="0 0 10 20"
                                FontSize="14"
                    VerticalAlignment="Top"
                    Width="150"
                    Height="40"
                                Image="{StaticResource image_exit_selected}"
                    Command="{Binding CloseCommand}"/>
            </DockPanel>

            <UniformGrid Margin="0 40 0 40" Rows="1">
                <CheckBox Content="AutoRun"
                          x:Name="cbAutoRun"
                          FontSize="14"
                        Width="120" Height="80" Margin="10"
                        Command="{Binding DataContext.SelectModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{x:Static defines:EMachineRunMode.Auto}">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox"
                               BasedOn="{StaticResource CheckBoxButtonStyle}">
                            <Style.Setters>
                                <Setter Property="Background" Value="LightSkyBlue"/>
                            </Style.Setters>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="Lime"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
                <CheckBox Content="ByPass"
                          FontSize="14"
                          x:Name="cbByPass"
                    Width="120" Height="80" Margin="10"
                    Command="{Binding DataContext.SelectModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{x:Static defines:EMachineRunMode.ByPass}">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox"
                            BasedOn="{StaticResource CheckBoxButtonStyle}">
                            <Style.Setters>
                                <Setter Property="Background" Value="LightSkyBlue"/>
                            </Style.Setters>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="Lime"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
                <CheckBox Content="DryRun"
                          FontSize="14"
                          x:Name="cbDryRun"
                    Width="120" Height="80" Margin="10"
                    Command="{Binding DataContext.SelectModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{x:Static defines:EMachineRunMode.Dryrun}">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox"
                            BasedOn="{StaticResource CheckBoxButtonStyle}">
                            <Style.Setters>
                                <Setter Property="Background" Value="LightSkyBlue"/>
                            </Style.Setters>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="Lime"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
                <CheckBox Content="Manual Interface"
                          FontSize="14"
                          x:Name="cbInterfaceOnly"
                    Width="120" Height="80" Margin="10"
                    Command="{Binding DataContext.SelectModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{x:Static defines:EMachineRunMode.ManualInterface}">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox"
                            BasedOn="{StaticResource CheckBoxButtonStyle}">
                            <Style.Setters>
                                <Setter Property="Background" Value="LightSkyBlue"/>
                            </Style.Setters>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="Lime"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
            </UniformGrid>
        </Grid>
    </Border>
</Window>
