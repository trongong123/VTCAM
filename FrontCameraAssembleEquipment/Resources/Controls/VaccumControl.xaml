<UserControl x:Class="FrontCameraAssembleEquipment.Resources.Controls.VaccumControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
             xmlns:device="clr-namespace:FrontCameraAssembleEquipment.Defines"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type device:Vaccum}}"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Border BorderBrush="Gray"
            CornerRadius="5"
            BorderThickness="1"
            Margin="2">
        <Border.Resources>
            <Style x:Key="OverrideBtnStyle"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource ActionButtonStyle}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter Property="Foreground"
                                Value="Black" />
                    </Trigger>

                    <Trigger Property="IsPressed"
                             Value="True">
                        <Setter Property="Foreground"
                                Value="Black" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Resources>
        <StackPanel Margin="5">
            <!--<TextBlock Text="[VACCUM]" 
                            FontWeight="Bold" 
                            HorizontalAlignment="Center" 
                            Margin="0,0,0,5"/>-->
            <TextBlock Text="{Binding Name}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Width="10"
                               Height="35"
                               RadiusX="3"
                               RadiusY="3"
                               Fill="{Binding IsVaccumOn, Converter={StaticResource BooleanToOnOffBrushConverter}}"
                               Stroke="Black"
                               StrokeThickness="1" />
                    <Button Style="{StaticResource OverrideBtnStyle}"
                            Grid.Column="1"
                            Background="{Binding VacOnOutput.Value, Converter={StaticResource BooleanToBrushesOutputValue}}"
                            Click="VaccumOn_Click"
                            Content="ON" />
                </Grid>
                <Separator Width="35"
                           Height="1"
                           Grid.Column="1"
                           Margin="3 0">
                    <Separator.LayoutTransform>
                        <RotateTransform Angle="90" />
                    </Separator.LayoutTransform>
                </Separator>
                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource OverrideBtnStyle}"
                            Content="OFF"
                            Background="{Binding VacOffOutput.Value, Converter={StaticResource BooleanToBrushesOutputValue}}"
                            Click="VaccumOff_Click" />
                    <Rectangle Width="10"
                               Grid.Column="1"
                               Height="35"
                               RadiusX="3"
                               RadiusY="3"
                               Fill="{Binding IsVaccumOff, Converter={StaticResource BooleanToOnOffBrushConverter}}"
                               Stroke="Black"
                               StrokeThickness="1" />
                </Grid>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
