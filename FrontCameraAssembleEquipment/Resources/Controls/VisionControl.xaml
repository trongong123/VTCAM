<UserControl x:Class="FrontCameraAssembleEquipment.Resources.Controls.VisionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
             xmlns:defines="clr-namespace:FrontCameraAssembleEquipment.Defines"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="400"
             >
    <Border BorderBrush="Gray" CornerRadius="3" BorderThickness="1" Margin="5" Padding="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <UniformGrid Rows="1" Margin="2">
                <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    -->
                <!--<Border Height="15" Width="15" Background="{Binding IsVisionConnected, Converter={StaticResource BooleanToOnOffBrushConverter}}" CornerRadius="2" Margin="5" />-->
                <!--
                    <TextBlock Text="Vision" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>-->
                <RadioButton GroupName="Inspection" Content="Rear FILM" Checked="RadioButton_Checked">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CheckTwoConveyor}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>

                <RadioButton GroupName="Inspection" Content="Front FILM" Checked="RadioButton_Checked"/>
                
                <RadioButton GroupName="Inspection" Content="Rear CAM" Checked="RadioButton_Checked">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CheckTwoConveyor}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
                
                <RadioButton GroupName="Inspection" Content="Front CAM" Checked="RadioButton_Checked"/>
                <RadioButton GroupName="Inspection" Content="BCR" Checked="RadioButton_Checked"/>
            </UniformGrid>

            <Button Grid.Row="1" Style="{StaticResource ActionButtonStyle}"
                Click="Inspection_Click"
                Content="INSPECTION" Width="auto"/>
        </Grid>
    </Border>
</UserControl>
