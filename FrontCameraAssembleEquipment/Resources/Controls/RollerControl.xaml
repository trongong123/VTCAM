<UserControl x:Class="FrontCameraAssembleEquipment.Resources.Controls.RollerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.Resources.Style"
             xmlns:device="clr-namespace:EQX.Device.SpeedController;assembly=EQX.Device"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type device:BD201SRollerController}}"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Border BorderBrush="Gray"
                CornerRadius="5"
                BorderThickness="1"
                Margin="2">
            <StackPanel Margin="5">
                <TextBlock Text="{Binding Id, Converter={StaticResource IdEnumDescriptionConverter}, ConverterParameter=Roller}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Style="{StaticResource ConveyorButtonStyle}"
                            Content="RUN"
                            Click="RunClick"
                            Background="{Binding IsRunStatus, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToBrushesOutputValue}}"/>
                    <Separator Height="1"
                               Width="35"
                               Margin="3 0"
                               Grid.Column="1">
                        <Separator.LayoutTransform>
                            <RotateTransform Angle="90" />
                        </Separator.LayoutTransform>
                    </Separator>
                    <Button Style="{StaticResource ConveyorButtonStyle}"
                            Content="STOP"
                            Click="StopClick"
                            Grid.Column="2"
                            Background="{Binding IsStopStatus, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToBrushesOutputValue}}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
