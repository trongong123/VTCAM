<UserControl x:Class="FrontCameraAssembleEquipment.Resources.Controls.CylinderControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
             mc:Ignorable="d"
             xmlns:converter="clr-namespace:FrontCameraAssembleEquipment.Converters"
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderBrush="Gray"
            CornerRadius="5"
            BorderThickness="1"
            Margin="2">
        <StackPanel Margin="5">
            <TextBlock Text="{Binding Name}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Width="10"
                               RadiusX="3"
                               RadiusY="3"
                               Stroke="Black"
                               StrokeThickness="1">
                        <Rectangle.Fill>
                            <MultiBinding Converter="{StaticResource CylinderButtonBrushConverter}">
                                <Binding Path="IsForward" />
                                <Binding Path="IsBackward" />
                                <Binding Path="CylinderType" />
                                <Binding Source="Forward" />
                            </MultiBinding>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Button Style="{StaticResource CylinderButtonStyle}"
                            Click="ForwardButton_Click"
                            Grid.Column="1"
                            Content="{Binding CylinderType, Converter={StaticResource CylinderTypeToButtonNameConverter}, ConverterParameter=true}">
                        <Button.Background>
                            <MultiBinding Converter="{StaticResource CylinderButtonBrushConverter}">
                                <Binding Path="IsOutForward" />
                                <Binding Path="IsOutBackward" />
                                <Binding Path="CylinderType" />
                                <Binding Source="Forward" />
                            </MultiBinding>
                        </Button.Background>
                    </Button>
                </Grid>
                <Separator Width="35"
                           Height="1"
                           Margin="3 0"
                           Grid.Column="1">
                    <Separator.LayoutTransform>
                        <RotateTransform Angle="90" />
                    </Separator.LayoutTransform>
                </Separator>
                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource CylinderButtonStyle}"
                            Click="BackwardButton_Click"
                            Content="{Binding CylinderType, Converter={StaticResource CylinderTypeToButtonNameConverter}, ConverterParameter=false}">
                        <Button.Background>
                            <MultiBinding Converter="{StaticResource CylinderButtonBrushConverter}">
                                <Binding Path="IsOutForward" />
                                <Binding Path="IsOutBackward" />
                                <Binding Path="CylinderType" />
                                <Binding Source="Backward" />
                            </MultiBinding>
                        </Button.Background>
                    </Button>
                    <Rectangle Width="10"
                               RadiusX="3"
                               RadiusY="3"
                               Grid.Column="1"
                               Stroke="Black"
                               StrokeThickness="1">
                        <Rectangle.Fill>
                            <MultiBinding Converter="{StaticResource CylinderButtonBrushConverter}">
                                <Binding Path="IsForward" />
                                <Binding Path="IsBackward" />
                                <Binding Path="CylinderType" />
                                <Binding Source="Backward" />
                            </MultiBinding>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Grid>
        </StackPanel>
    </Border>

</UserControl>
