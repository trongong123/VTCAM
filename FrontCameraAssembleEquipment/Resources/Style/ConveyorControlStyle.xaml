<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:cvt="clr-namespace:EQX.UI.Converters;assembly=EQX.UI"
                    x:Class="FrontCameraAssembleEquipment.Resources.Style.ConveyorControlStyle"
                    xmlns:converter="clr-namespace:FrontCameraAssembleEquipment.Converters"
                    xmlns:inout="clr-namespace:EQX.InOut;assembly=EQX.InOut">
    <converter:BooleanToBrushesOutputValue x:Key="BooleanToBrushesOutputValue"/>
    <Style x:Key="ConveyorButtonStyle" TargetType="Button">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="ConveyorRunButtonStyle" BasedOn="{StaticResource ConveyorButtonStyle}">
        <EventSetter Event="Click" Handler="ConveyorRun_Click"/>
    </Style>

    <Style TargetType="Button" x:Key="ConveyorStopButtonStyle" BasedOn="{StaticResource ConveyorButtonStyle}">
        <EventSetter Event="Click" Handler="ConveyorStop_Click"/>
    </Style>
    <DataTemplate x:Key="ConveyorControlTemplate" DataType="{x:Type inout:ConveyorBase}">
        <DataTemplate.Resources>
            <converter:BooleanToBrushesOutputValue x:Key="BooleanToBrushesOutputValue"/>
        </DataTemplate.Resources>
        <Grid>
            <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="3">
                <StackPanel Margin="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource ConveyorRunButtonStyle}"
                                Content="RUN"
                                Grid.Column="0"
                                Background="{Binding OutRunStatus, Converter={StaticResource BooleanToBrushesOutputValue}}" />
                        <Separator Width="35"
                                   Height="1"
                                   Margin="3 0"
                                   Grid.Column="1">
                            <Separator.LayoutTransform>
                                <RotateTransform Angle="90" />
                            </Separator.LayoutTransform>
                        </Separator>
                        <Button Style="{StaticResource ConveyorStopButtonStyle}"
                                Content="STOP"
                                Grid.Column="2"
                                Background="{Binding OutStopStatus, Converter={StaticResource BooleanToBrushesOutputValue}}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

</ResourceDictionary>