<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:Class="FrontCameraAssembleEquipment.Resources.Style.CylinderControlStyle"
                    xmlns:cvt="clr-namespace:EQX.UI.Converters;assembly=EQX.UI"
                    xmlns:converter="clr-namespace:FrontCameraAssembleEquipment.Converters"
                    xmlns:inout="clr-namespace:EQX.InOut;assembly=EQX.InOut">
    <converter:IdEnumDescriptionConverter x:Key="IdEnumDescriptionConverter" />
    <converter:BooleanToBrushesOutputValue x:Key="BooleanToBrushesOutputValue" />

    <Style x:Key="CylinderButtonStyle"
           TargetType="Button">
        <Setter Property="Margin"
                Value="3" />
        <Setter Property="FontWeight"
                Value="Bold" />
        <Setter Property="BorderThickness"
                Value="2" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>