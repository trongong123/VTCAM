<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:HeaderViewModel}"
             xmlns:eqxui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             Foreground="White"
             mc:Ignorable="d"
             d:DesignHeight="70" d:DesignWidth="800">
    <Grid Height="70" Background="{StaticResource PrimaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Information.Customer}"
                   Margin="5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Grid.RowSpan="2"/>

        <TextBlock Text="{Binding Information.MachineName}"
                    FontFamily="{StaticResource FontHighlight}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    FontSize="25"
                   FontWeight="Bold"
                    Grid.Column="1"
                    Grid.RowSpan="2"/>

        <TextBlock Grid.Column="2" Margin="5"
                   Text="{Binding RecipeSelector.RecipeSetting.CurrentRecipe, StringFormat=Model: {0}}"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"/>

        <StackPanel Orientation="Vertical" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Right" Margin="5 0">
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Right"
                       FontFamily="Consolas"
                       Text="{Binding Now, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}">
            </TextBlock>
            <TextBlock TextAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="Consolas"
                       Text="{Binding Information.SoftwareVersion}">
            </TextBlock>
        </StackPanel>

    </Grid>
</UserControl>
