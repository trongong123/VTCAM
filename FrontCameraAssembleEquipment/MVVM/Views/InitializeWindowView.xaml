<Window x:Class="FrontCameraAssembleEquipment.MVVM.Views.InitializeWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
        mc:Ignorable="d"
        Name="root"
        Top="70"
        Left="-5"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
        Title="Initialize" Height="620" Width="700">
    <Window.Resources>
        <DataTemplate x:Key="ProcessOriginStatusTemplate">
            <Border BorderBrush="Gray"
                IsEnabled="{Binding DataContext.MachineStatus.IsStandByProcessMode,ElementName=root}"
                Cursor="Hand" BorderThickness="1"
                PreviewMouseDown="Border_PreviewMouseDown" >
                <Grid>
                    <!--<Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>-->
                    <Label Content="{Binding Name, Converter={StaticResource ProcessNameToDescriptionConverter}}"
                       FontWeight="Bold"
                       Background="{Binding IsOriginOrInitSelected,Converter={StaticResource BooleanToBackgroundUnitInitConverter}}"
                       FontSize="14" Padding="10"
                       HorizontalContentAlignment="Center"
                       Foreground="Black" />
                    <!--<Label Content="{Binding IsWarning,Converter={StaticResource ProcessAlarmWarningStatusToLabelContentConverter}, ConverterParameter=Warning}"
                       Grid.Row="1"
                       FontWeight="SemiBold"
                       HorizontalContentAlignment="Center"
                       Background="{Binding IsWarning,Converter={StaticResource ProcessAlarmWarningStatusToBackgroundConverter}, ConverterParameter=Warning}" />-->
                </Grid>
            </Border>
        </DataTemplate>
        <Style TargetType="ContentControl">
            <Style.Setters>
                <Setter Property="ContentTemplate"
                    Value="{StaticResource ProcessOriginStatusTemplate}" />
            </Style.Setters>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Background="#E8E8E8"
            Height="50"
            BorderBrush="Gray"
            BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock x:Name="ClockText" Text="Init"
            VerticalAlignment="Center"
            FontWeight="Bold" FontSize="16"
            Margin="10,0,0,0"/>
                <ui:ImageButton Content="Exit"
                    Height="40"
                Margin="0 0 10 0"
                    Width="150"
                    HorizontalAlignment="Right"
                    Image="{StaticResource image_exit_selected}"
        Click="ExitButton_Click"/>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Border Grid.Column="0"
        BorderBrush="{StaticResource PrimaryBorderBrush}"
        Background="White"
        BorderThickness="1"
        Margin="5 10">
                <Viewbox Stretch="Uniform">
                    <Image Source="{StaticResource machine_top_view}"
                Stretch="Uniform" Opacity="0.5"/>
                </Viewbox>
            </Border>

            <Canvas Grid.Column="0">
                <ContentControl Content="{Binding Processes.TrayInCVProcess}"
                    Canvas.Left="144"
                    Canvas.Top="40"/>
                <ContentControl Content="{Binding Processes.TrayOutCVProcess}"
                    Canvas.Left="280"
                    Canvas.Top="40" />
                <ContentControl Content="{Binding Processes.TrayInElevatorProcess}"
                    Canvas.Left="165"
                    Canvas.Top="100"/>
                <ContentControl Content="{Binding Processes.TrayOutElevatorProcess}"
                    Canvas.Left="280"
                    Canvas.Top="100" />
                <ContentControl Content="{Binding Processes.TransferHeadProcess}"
                    Canvas.Left="210"
                    Canvas.Top="150" />
                <ContentControl Content="{Binding Processes.SpongeDetachProcess}"
                    Canvas.Left="260"
                    Canvas.Top="200"/>
                <ContentControl Content="{Binding Processes.CameraFlipperProcess}"
                    Canvas.Left="145"
                    Canvas.Top="200" />

                <Canvas>
                    <Canvas.Style>
                        <Style TargetType="Canvas">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CheckTwoConveyor}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Canvas.Style>
                    
                    <ContentControl Content="{Binding Processes.RearCVSetLoadProcess}"
                    Canvas.Left="30"
                    Canvas.Top="310" />
                    <ContentControl Content="{Binding Processes.RearCVSetFilmDetachProcess}"
                    Canvas.Left="170"
                    Canvas.Top="310" />
                    <ContentControl Content="{Binding Processes.RearCVSetCamAssembleProcess}"
                    Canvas.Left="345"
                    Canvas.Top="310" />
                    <ContentControl Content="{Binding Processes.RearCVSetUnloadProcess}"
                    Canvas.Left="540"
                    Canvas.Top="310" />
                </Canvas>


                <ContentControl Content="{Binding Processes.FilmDetachProcess}"
                    Canvas.Left="170"
                    Canvas.Top="355" />
                <ContentControl Content="{Binding Processes.CameraAssembleProcess}"
                    Canvas.Left="300"
                    Canvas.Top="355"/>

                <ContentControl Content="{Binding Processes.FrontCVSetLoadProcess}"
                    Canvas.Left="30"
                    Canvas.Top="400" />
                <ContentControl Content="{Binding Processes.FrontCVSetFilmDetachProcess}"
                    Canvas.Left="170"
                    Canvas.Top="400" />
                <ContentControl Content="{Binding Processes.FrontCVSetCamAssembleProcess}"
                    Canvas.Left="345"
                    Canvas.Top="400" />
                <ContentControl Content="{Binding Processes.FrontCVSetUnloadProcess}"
                    Canvas.Left="540"
                    Canvas.Top="400" />

            </Canvas>

        </Grid>
        <UniformGrid Rows="1"
                Grid.Row="2"
            Grid.Column="1"
            Margin="3 0 3 5">
            <UniformGrid.Resources>
                <Style TargetType="{x:Type ui:ImageButton}"
                    BasedOn="{StaticResource {x:Type ui:ImageButton}}">
                    <Style.Setters>
                        <Setter Property="Padding" Value="5 10" />
                        <Setter Property="Margin" Value="2" />
                        <Setter Property="Height" Value="50" />
                        <Setter Property="FontSize" Value="13" />
                    </Style.Setters>
                </Style>
            </UniformGrid.Resources>
            <ui:ImageButton Content="Select All"
                        Image="{StaticResource image_select_selected}"
                        Command="{Binding SelectAllCommand}"
                        IsEnabled="{Binding MachineStatus.IsStandByProcessMode}" />
            <ui:ImageButton Content="Unselect All"
                        Image="{StaticResource image_unselect_all_selected}"
                        Command="{Binding UnSelectAllCommand}"
                        IsEnabled="{Binding MachineStatus.IsStandByProcessMode}" />
            <ui:ImageButton Content="Init"
                        Image="{StaticResource image_idling_selected}"
                        Command="{Binding InitializeCommand}"
                        IsEnabled="{Binding MachineStatus.IsStandByProcessMode}" />
        </UniformGrid>
    </Grid>
</Window>
