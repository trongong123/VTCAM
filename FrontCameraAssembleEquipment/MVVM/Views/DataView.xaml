<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.DataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             xmlns:control="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             Loaded="DataView_Loaded"
             d:DataContext="{d:DesignInstance Type=vm:DataViewModel}"
             d:DesignHeight="700" d:DesignWidth="1024">
    <TabControl>
        <TabControl.Template>
            <ControlTemplate TargetType="TabControl">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!--Header-->
                    <UniformGrid Rows="1" IsItemsHost="True" Visibility="{Binding DataContext.IsSetCV, Converter={StaticResource BooleanToVisibilityInvertConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                    <!--Content-->
                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" Margin="3"/>
                </Grid>
            </ControlTemplate>

        </TabControl.Template>
        <TabItem Header="Recipe"
                 Width="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.42*"/>
                    <ColumnDefinition Width="0.6*"/>
                </Grid.ColumnDefinitions>

                <!--Column 1-->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.2*"/>
                        <RowDefinition Height="0.9*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0">
                            <Expander Header="System Option" IsExpanded="True" FontSize="13">
                                <StackPanel Margin="2">

                                    <CheckBox IsChecked="{Binding RecipeSelector.CurrentRecipe.GlobalRecipe.UseEDMLog}"
                                              Height="43"
                                              Content="Use EDM Log"
                                              Tag="Enable to Using EDM Log" />
                                    <CheckBox IsChecked="{Binding RecipeSelector.CurrentRecipe.GlobalRecipe.UseScaner}"
                                              Height="43"
                                              Content="Use Scaner" 
                                              Tag="Enable to Using Scaner" />

                                    <ContentControl Content="{Binding CameraTypeSelectViewModel}"
                                                    Height="100"/>

                                    <UniformGrid HorizontalAlignment="Center" Rows="1">
                                        <TextBlock Text="Rollers COM:" VerticalAlignment="Center" Margin="10" Foreground="Black"/>
                                        <ComboBox ItemsSource="{Binding AvailableComPorts}" SelectedItem="{Binding SerialCOMConfig.COMPort}"/>
                                        <TextBlock Text="Baudrate:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="10" Foreground="Black"/>
                                        <ComboBox ItemsSource="{Binding BaudrateList}" SelectedItem="{Binding SerialCOMConfig.Baudrate}"/>
                                    </UniformGrid>

                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Grid.Row="1">
                            <ListBox x:Name="_listBoxModel"
                             VerticalContentAlignment="Stretch"
                             ItemsSource="{Binding RecipeSelector.ValidRecipes}"
                             SelectedIndex="0"
                             AlternationCount="100"
                             SelectedItem="{Binding SelectedRecipe, Mode=OneWayToSource}">
                                <ListBox.Style>
                                    <Style TargetType="{x:Type ListBox}">
                                        <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListBox}">
                                                    <GroupBox Header="{DynamicResource str_ModelList}">
                                                        <ItemsPresenter Grid.Row="1" />
                                                    </GroupBox>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="5" />
                                        <Setter Property="Margin" Value="2" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <UniformGrid HorizontalAlignment="Center" Grid.Row="2" Columns="5">
                        <UniformGrid.Resources>
                            <Style TargetType="{x:Type ui:ImageButton}"
                        BasedOn="{StaticResource {x:Type ui:ImageButton}}">
                                <Style.Setters>
                                    <Setter Property="Padding" Value="2 10" />
                                    <Setter Property="Margin" Value="2" />
                                    <Setter Property="Height" Value="40"/>
                                    <Setter Property="Width" Value="auto" />
                                    <Setter Property="FontSize" Value="13" />
                                </Style.Setters>
                            </Style>
                        </UniformGrid.Resources>

                        <ui:ImageButton Content="{DynamicResource str_Select}"
                                Image="{StaticResource image_setting_selected2}"
                                Click="ChangeButton_Click"/>
                        <ui:ImageButton Content="{DynamicResource str_Save}"
                                Command="{Binding SaveRecipeCommand}"
                                Image="{StaticResource image_save_all_selected}"/>
                        <ui:ImageButton Content="{DynamicResource str_Load}"
                                Image="{StaticResource image_export_selected}"
                                Click="ReloadButton_Clicked" />
                        <ui:ImageButton Content="{DynamicResource str_Refresh}"
                                Image="{StaticResource image_refresh_selected}"
                                Command="{Binding RefreshRecipeCommand}"/>
                        <ui:ImageButton Content="{DynamicResource str_Copy}"
                                Image="{StaticResource image_copy_selected}"
                                Command="{Binding CopyRecipeCommand}"/>
                    </UniformGrid>
                </Grid>

                <Border Grid.Column="1" BorderThickness="1" BorderBrush="{StaticResource PrimaryBorderBrush}">
                    <TabControl x:Name="CurrentRecipe_TabControl">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!--Header-->
                                    <UniformGrid Rows="1" IsItemsHost="True" />

                                    <!--Content-->
                                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" Margin="3"/>
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>
                    </TabControl>
                </Border>

            </Grid>

        </TabItem>

        <TabItem Header="Motion Config"
                 Width="Auto">
            <DockPanel LastChildFill="True">
                <control:MotionsSpeedConfigView DockPanel.Dock="Top" MotionList="{Binding DataContext.AllMotions, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <ui:ImageButton Content="{DynamicResource str_Save}"
                                    Command="{Binding SaveMotionConfigCommand}"
                                    Image="{StaticResource image_save_all_selected}"
                                    FontSize="12"
                                    Height="40"
                                    Width="100" />
            </DockPanel>
        </TabItem>
        
        <TabItem Header="CV Delay Time"
                 Width="Auto">
            <StackPanel Orientation="Vertical">
                <StackPanel x:Name="CVDelayTimeStackPanel">
                </StackPanel>
                <ui:ImageButton Content="{DynamicResource str_Save}"
                                Command="{Binding SaveRecipeCommand}"
                                Image="{StaticResource image_save_all_selected}"
                                Margin="0 40 0 0"
                                FontSize="12"
                                Height="40"
                                Width="100" />
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>
