<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.VisionManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <GroupBox Grid.Column="2"
                  Style="{StaticResource GroupBoxBorderHeaderStyle}"
                  Grid.Row="1"
                  Header="VISION">
            <ContentControl Margin="200 100 200 100"
                            Content="{Binding VisionProcess}" />
        </GroupBox>
    </Grid>
</UserControl>
