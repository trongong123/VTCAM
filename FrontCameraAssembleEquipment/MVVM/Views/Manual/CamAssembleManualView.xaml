<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.CamAssembleManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             d:DataContext="{d:DesignInstance Type={x:Type vm:CamAssembleManualViewModel}}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="{x:Type GroupBox}"
               BasedOn="{StaticResource GroupBoxBorderHeaderStyle}">
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1.3*" />
            <ColumnDefinition Width="0.8*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!--<CheckBox Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Left" Panel.ZIndex="1" Style="{StaticResource CheckBoxButtonStyle}" Margin="6" Width="Auto"
IsChecked="{Binding IsIOShow, Mode=TwoWay, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}" 
Content="I/O List"/>-->

        <GroupBox Header="IO STATUS"
                  Grid.RowSpan="2">
            <TabControl>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <UniformGrid Rows="1"
                                         IsItemsHost="True" />

                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              Margin="3" />
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabItem Header="Input"
                         Height="35">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="11*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>

                        <ItemsControl>
                            <ItemsControl.ItemsSource>
                                <!--<Binding Path="Inputs" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=UserControl}" />-->
                                <MultiBinding Converter="{StaticResource InOutListPageConverter}">
                                    <Binding Path="Inputs"/>
                                    <Binding Path="SelectedInputPage"/>
                                </MultiBinding>
                            </ItemsControl.ItemsSource>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"
                                                 Rows="9" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}"
                                                    Margin="2"
                                                    FontSize="12" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <UniformGrid Margin="0 5 0 0"
                                     Rows="1"
                                     Grid.Row="1"
                                     Visibility="{Binding IsMaxIOPerPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="Prev"
                                    Command="{Binding DecreaseIOPageCommand}" />
                            <Button Content="Next"
                                    Command="{Binding IncreaseIOPageCommand}" />
                        </UniformGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="Output"
                         Height="35">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="11*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <ItemsControl>
                            <ItemsControl.ItemsSource>
                                <Binding Path="Outputs"/>
                            </ItemsControl.ItemsSource>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"
                                                 Rows="9" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}"
                                                    Margin="2"
                                                    FontSize="12" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </TabItem>
            </TabControl>
        </GroupBox>

        <GroupBox Grid.Column="1"
                  Grid.Row="0"
                  Grid.RowSpan="2"
                  Header="FUNCTION">
            <UniformGrid Columns="2">
                <StackPanel>
                    <ContentControl Content="{Binding CamPickerVac}" />
                </StackPanel>
                <StackPanel>
                </StackPanel>
            </UniformGrid>
        </GroupBox>

        <GroupBox Grid.Column="2"
                  Grid.Row="0"
                  Grid.RowSpan="2"
                  Header="POSITION">
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding TeachingPositions}"
                          Margin="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Description}"
                                Background="{Binding IsOnGroupPosition, Converter={StaticResource BooleanToBrushesOutputValue}}"
                                FontSize="14"
                                Margin="2"
                                Command="{Binding DataContext.PositionMoveCommand , RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding .}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="1"
                                     VerticalAlignment="Top" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </GroupBox>

    </Grid>
</UserControl>
