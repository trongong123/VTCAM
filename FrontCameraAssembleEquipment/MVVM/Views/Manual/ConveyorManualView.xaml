<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.ConveyorManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             d:DataContext="{d:DesignInstance Type={x:Type vm:ConveyorManualViewModel}}"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin"
                    Value="1" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="#DDD" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border CornerRadius="5"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                Background="White"
                                SnapsToDevicePixels="True">
                            <DockPanel>
                                <Border Background="#E1E1E2"
                                        DockPanel.Dock="Top"
                                        Padding="8,4"
                                        CornerRadius="5,5,0,0">
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontWeight="Bold"
                                               Foreground="Black"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="13" />
                                </Border>

                                <ContentPresenter />
                            </DockPanel>
                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition>
                <RowDefinition.Style>
                    <Style TargetType="RowDefinition">
                        <Setter Property="Height" Value="1*"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding checkDeleteRear}" Value="false">
                                <Setter Property="Height" Value="auto"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </RowDefinition.Style>
            </RowDefinition>
        </Grid.RowDefinitions>
        <!--REAR CV-->
        <GroupBox Grid.Row="0"
                  Grid.ColumnSpan="3"
                  Grid.Column="0"
                  Header="REAR">
            <GroupBox.Style>
                <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding checkDeleteRear}"
                             Value="false">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </GroupBox.Style>
            
            <UniformGrid Columns="4">
                <Border BorderBrush="Gray"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="INPUT CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ContentControl Content="{Binding RearCVsInCv}" 
                                        Height="55"/>
                        <Label Content="MANUAL CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ContentControl Content="{Binding RearManualInCv}" 
                                        Height="55"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="DETACH CV"
                               HorizontalContentAlignment="Center"
                               FontWeight="Bold" />
                        <ItemsControl ItemsSource="{Binding RearCVsDetachCv}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding RearCylindersDetachCv}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="ASSEMBLE CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ItemsControl ItemsSource="{Binding RearCVsAssembleCv}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding RearCylindersAssembleCv}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="OUTPUT CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ItemsControl ItemsSource="{Binding RearCVsOutCv}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding RearCylindersOutCv}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </GroupBox>


        <!--FRONT CV-->
        <GroupBox  Grid.ColumnSpan="3" 
                   Grid.Column="0" 
                   Header="FRONT">
            <GroupBox.Style>
                <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                    <Setter Property="Grid.Row" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding checkDeleteRear}" Value="false">
                            <Setter Property="Grid.Row" Value="0"/>
                        </DataTrigger>
                        
                    </Style.Triggers>
                </Style>
            </GroupBox.Style>
            <UniformGrid Columns="4">
                <Border BorderBrush="Gray"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="INPUT CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ContentControl Content="{Binding CVsInCv}" 
                                        Height="55"/>
                        <Label Content="MANUAL CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ContentControl Content="{Binding ManualInCv}" 
                                        Height="55"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="DETACH CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ItemsControl ItemsSource="{Binding CVsDetachCv}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CylindersDetachCv}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="ASSEMBLE CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ItemsControl ItemsSource="{Binding CVsAssembleCv}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CylindersAssembleCv}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="OUTPUT CV"
                               HorizontalAlignment="Center"
                               FontWeight="Bold" />
                        <ItemsControl ItemsSource="{Binding CVsOutCv}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CylindersOutCv}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <Button Content="TEST FRONT UNLOAD"
                                Command="{Binding TestOneConveyorFrontUnloadCommand}"
                                Margin="4"
                                Height="32" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </GroupBox>

    </Grid>
</UserControl>
