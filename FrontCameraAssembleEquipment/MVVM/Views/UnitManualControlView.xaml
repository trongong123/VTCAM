<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.UnitManualControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:views="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             xmlns:cvt="clr-namespace:FrontCameraAssembleEquipment.Converters"
             xmlns:control="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="1024">
    <UserControl.Resources>
        <cvt:InOutListPageConverter x:Key="InOutListPageConverter" />
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin"
                    Value="5" />
            <Setter Property="Padding"
                    Value="5" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="#DDD" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border CornerRadius="5"
                                BorderBrush="#DDD"
                                BorderThickness="1"
                                Background="White"
                                SnapsToDevicePixels="True">
                            <DockPanel>
                                <Border Background="#E1E1E2"
                                        DockPanel.Dock="Top"
                                        Padding="8,4"
                                        CornerRadius="5,5,0,0">
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontWeight="SemiBold"
                                               Foreground="Black"
                                               VerticalAlignment="Center"
                                               FontSize="13" />
                                </Border>

                                <ContentPresenter />
                            </DockPanel>
                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1.3*" />
            <ColumnDefinition Width="0.8*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!--<CheckBox Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Left" Panel.ZIndex="1" Style="{StaticResource CheckBoxButtonStyle}" Margin="6" Width="Auto"
                  IsChecked="{Binding IsIOShow, Mode=TwoWay, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}" 
                  Content="I/O List"/>-->

        <GroupBox Header="IO STATUS"
                  Grid.RowSpan="2">
            <TabControl>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <UniformGrid Rows="1"
                                         IsItemsHost="True" />

                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              Margin="3" />
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabItem Header="Input"
                         Height="35">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="11*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>

                        <ItemsControl>
                            <ItemsControl.ItemsSource>
                                <!--<Binding Path="Inputs" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=UserControl}" />-->
                                <MultiBinding Converter="{StaticResource InOutListPageConverter}">
                                    <Binding Path="Inputs"
                                             RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=UserControl}" />
                                    <Binding Path="SelectedInputPage"
                                             RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=UserControl}" />
                                </MultiBinding>
                            </ItemsControl.ItemsSource>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"
                                                 Rows="9" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}"
                                                    Margin="2"
                                                    FontSize="12" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <UniformGrid Margin="0 5 0 0"
                                     Rows="1"
                                     Grid.Row="1"
                                     Visibility="{Binding IsMaxIOPerPage, Converter={StaticResource BooleanToVisibilityConverter}, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <Button Content="Prev"
                                    Command="{Binding DecreaseIOPageCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}" />
                            <Button Content="Next"
                                    Command="{Binding IncreaseIOPageCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}" />
                        </UniformGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="Output"
                         Height="35">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="11*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <ItemsControl>
                            <ItemsControl.ItemsSource>
                                <Binding Path="Outputs"
                                         RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=UserControl}" />
                            </ItemsControl.ItemsSource>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"
                                                 Rows="9" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding .}"
                                                    Margin="2"
                                                    FontSize="12" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </TabItem>
            </TabControl>
        </GroupBox>

        <GroupBox Grid.Column="1"
                  Grid.Row="0"
                  Grid.RowSpan="2"
                  Header="FUNCTION">
            <WrapPanel Orientation="Vertical"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <ItemsControl ItemsSource="{Binding Rolllers,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding .}"
                                            Margin="1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding CVs,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding .}"
                                            Margin="1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding Cylinders, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding Vaccums,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding .}"
                                            Margin="1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </GroupBox>

        <GroupBox Grid.Column="2"
                  Grid.Row="0"
                  Header="POSITION">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Column="2"
                            Grid.Row="0"
                            Margin="5"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Panel.ZIndex="1"
                            Visibility="{Binding IsCamHeadProcess, Converter={StaticResource BooleanToVisibilityConverter}, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                    <TextBlock Text="CV: "
                               VerticalAlignment="Center" />
                    <!--<CheckBox Content="{Binding IsFrontCv, Mode=TwoWay, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Converter={StaticResource PosLineBoolenToStringConverter}}" Style="{StaticResource CheckBoxButtonStyle}"
                      IsChecked="{Binding IsFrontCv, Mode=TwoWay, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                      VerticalAlignment="Center" Width="50"/>-->
                    <RadioButton IsChecked="{Binding IsFrontCv, Mode=TwoWay, Converter={StaticResource BooleanNegationConverter}, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                 Content=" Rear "
                                 Width="50"
                                 VerticalAlignment="Center" />
                    <RadioButton IsChecked="{Binding IsFrontCv, Mode=TwoWay, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                 Content=" Front "
                                 Width="50"
                                 VerticalAlignment="Center" />
                </StackPanel>
                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding TeachingPositions, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                              Margin="2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Description}"
                                    Background="{Binding IsOnGroupPosition, Converter={StaticResource BooleanToBrushesOutputValue}}"
                                    FontSize="14"
                                    Margin="2"
                                    Command="{Binding DataContext.PositionMoveCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                    CommandParameter="{Binding .}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1"
                                         VerticalAlignment="Top" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Column="2"
                  Grid.Row="1"
                  Header="VISION">
            <ContentControl Margin="0 10"
                            Content="{Binding DataContext.VisionProcess, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </GroupBox>
    </Grid>

</UserControl>
