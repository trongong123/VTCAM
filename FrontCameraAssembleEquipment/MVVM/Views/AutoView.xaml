<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.AutoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:cvt="clr-namespace:EQX.UI.Converters;assembly=EQX.UI"
             xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             xmlns:control="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
             d:DataContext="{d:DesignInstance Type=vm:AutoViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="605"
             d:DesignWidth="1024">

    <UserControl.Resources>
        <cvt:BooleanToOnOffBrushConverter x:Key="BooleanToOnOffBrushConverter" />

        <Style TargetType="RadioButton"
               BasedOn="{StaticResource ButtonLikeRadioButtonStyle}">
            <Style.Setters>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="3"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="GroupName" Value="CameraTypeGroupName"/>
            </Style.Setters>
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin"
            Value="3" />
            <Setter Property="Padding"
            Value="3" />
            <Setter Property="BorderThickness"
            Value="1" />
            <Setter Property="BorderBrush"
            Value="#DDD" />
            <Setter Property="Background"
            Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border CornerRadius="5"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        Background="White"
                        SnapsToDevicePixels="True">
                            <DockPanel>
                                <Border Background="#E1E1E2"
                                DockPanel.Dock="Top"
                                Padding="8,4"
                                CornerRadius="5,5,0,0">
                                    <TextBlock Text="{TemplateBinding Header}"
                                       FontWeight="SemiBold"
                                       Foreground="Black"
                                       VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                       FontSize="13" />
                                </Border>

                                <ContentPresenter />
                            </DockPanel>
                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button Style="{StaticResource ContentOnlyButtonStyle}" Grid.Column="0" Content="Dev Mode" VerticalAlignment="Top"
                Width="100"
                Height="50"
                HorizontalAlignment="Left" Margin="0 -50" 
                Background="Transparent" Foreground="Transparent" BorderBrush="Transparent" 
                Command="{Binding DevViewCommand}"/>
        
        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="194"/>
                <ColumnDefinition Width="287"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="250"/>
                <RowDefinition />
                <RowDefinition Height="10"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Image Grid.ColumnSpan="4" Grid.RowSpan="9" Margin="30 30 50 30"
                   Source="{StaticResource machine_top_view}"
                   Stretch="Uniform" Opacity="0.4"/>

            <!--Rear Door-->
            <Border Grid.Row="1" Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="10 0 -1.5 0"
                    Background="{Binding Devices.Inputs.RearDoor.Value, Converter={StaticResource DoorStatusToBrushConverter}}" 
                    BorderBrush="{StaticResource HighLightBorderBrush}"
                    BorderThickness="1"/>

            <!--Front Door-->
            <Border Grid.Row="4" Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="10 0 -1.5 0"
                    Background="{Binding Devices.Inputs.FrontDoor.Value, Converter={StaticResource DoorStatusToBrushConverter}}"
                    BorderBrush="{StaticResource HighLightBorderBrush}"
                    BorderThickness="1"/>

            <!--Right Door-->
            <Border Grid.Row="2" Grid.Column="2"
                    Margin="1 0 -1.5 0"
                    Background="{Binding Devices.Inputs.RightDoor.Value, Converter={StaticResource DoorStatusToBrushConverter}}"
                    BorderBrush="{StaticResource HighLightBorderBrush}"
                    BorderThickness="1"/>
        </Grid>

        <ContentControl Content="{Binding CameraTypeSelectViewModel}"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="10 3 5 0"
                        Width="80"
                        Height="Auto"
                        IsEnabled="False"/>

        <Button Content="Tray Out"
                Margin="0 170 10 120"
                Width="70"
                Height="90"
                VerticalAlignment="Top"
                FontSize="12"
                FontWeight="SemiBold"
                HorizontalAlignment="Right"
                Command="{Binding TrayOutCommand}"
                Background="{Binding MachineStatus.IsTrayOut, Converter={StaticResource BoolenToBrushesStartStopButton}, ConverterParameter=InOutStop}">
            <Button.Effect>
                <DropShadowEffect Color="Silver"
                                  Opacity="0.5"
                                  BlurRadius="3" />
            </Button.Effect>
        </Button>

        <Button Content="CAM&#x0A;Supply&#x0A;Stop" Margin="0 270 10 120" Width="70" Height="90"
                VerticalAlignment="Top"
                FontSize="12"
                FontWeight="SemiBold"
                HorizontalAlignment="Right"
                Command="{Binding PickupStopCommand}"
                Background="{Binding MachineStatus.IsPickUpStop, Converter={StaticResource BoolenToBrushesStartStopButton}, ConverterParameter=InOutStop}">
            <Button.Effect>
                <DropShadowEffect Color="Silver"
                    Opacity="0.5"
                    BlurRadius="3"/>
            </Button.Effect>
        </Button>

        <Button Content="Vision" Margin="7 37 34 0" Width="174" Height="60"
                FontSize="12"
                FontWeight="SemiBold"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Command="{Binding VisionPGMChangeCommand}">
            <Button.Effect>
                <DropShadowEffect Color="Silver"
                    Opacity="0.5"
                    BlurRadius="3"/>
            </Button.Effect>
        </Button>

        <Canvas Grid.Column="0" Panel.ZIndex="1">
            <!--<Border Canvas.Top="180" Canvas.Left="238" Panel.ZIndex="1" >
                <CheckBox Style="{StaticResource CheckBoxButtonStyle}" Content="{Binding TrayType2, Converter={StaticResource BooleanToStringTrayTypeNameConverter}}"
                      IsChecked="{Binding TrayType2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
            </Border>-->
            <Border Margin="55 0" Width="205"
                    Canvas.Top="145"
                    Canvas.Left="185"
                    VerticalAlignment="Center" HorizontalAlignment="Left" Background="White">
                <Border.Effect>
                    <DropShadowEffect Color="Silver"
                                        Opacity="0.5"
                                        BlurRadius="3"/>
                </Border.Effect>
                <StackPanel>
                    <Border BorderBrush="Black" BorderThickness="1 1 1 0"
                            VerticalAlignment="Center"
                            Height="25">
                        <Label Content="Barcode"
                               VerticalAlignment="Top"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalContentAlignment="Top"
                               HorizontalAlignment="Center"/>
                    </Border>
                    <TextBox TextAlignment="Center" BorderBrush="Black" Text="{Binding VisionProcess.BarcodeId, Mode=OneWay}"
                             IsReadOnly="True"
                             VerticalContentAlignment="Center"
                             Height="25"
                             FontSize="12" FontWeight="Bold" Padding="1"/>
                </StackPanel>
            </Border>
            
            <ContentControl Canvas.Top="60" Canvas.Left="370" Content="{Binding MaterialStatusList.TrayOutMaterialStatus}"/>
            <ContentControl Canvas.Top="60" Canvas.Left="240" Content="{Binding MaterialStatusList.TrayInMaterialStatus}"/>
            <ContentControl Canvas.Top="210" Canvas.Left="240" Content="{Binding MaterialStatusList.TrayHeadMaterialStatus}"/>
            <ContentControl Canvas.Top="210" Canvas.Left="370" Content="{Binding MaterialStatusList.PreAlignMaterialStatus}"/>
            <ContentControl Canvas.Top="290" Canvas.Left="240" Content="{Binding MaterialStatusList.RotatorMaterialStatus}"/>

            <ContentControl Canvas.Top="290" Canvas.Left="370" Content="{Binding MaterialStatusList.CamHeadMaterialStatus}"/>
            
            <ContentControl Canvas.Top="378" Canvas.Left="120" Content="{Binding MaterialStatusList.RearSetInCvMaterialStatus}"/>
            <ContentControl Canvas.Top="378" Canvas.Left="240" Content="{Binding MaterialStatusList.RearSetDetachCvMaterialStatus}"/>
            <ContentControl Canvas.Top="378" Canvas.Left="370" Content="{Binding MaterialStatusList.RearSetAssembleCvMaterialStatus}"/>
            <ContentControl Canvas.Top="378" Canvas.Left="480" Content="{Binding MaterialStatusList.RearSetOut1CvMaterialStatus}"/>
            <ContentControl Canvas.Top="378" Canvas.Left="575" Content="{Binding MaterialStatusList.RearSetOut2CvMaterialStatus}"/>
            <ContentControl Canvas.Top="378" Canvas.Left="670" Content="{Binding MaterialStatusList.RearSetOut3CvMaterialStatus}"/>
            
            <ContentControl Canvas.Top="470" Canvas.Left="120" Content="{Binding MaterialStatusList.FrontSetInCvMaterialStatus}"/>
            <ContentControl Canvas.Top="470" Canvas.Left="240" Content="{Binding MaterialStatusList.FrontSetDetachCvMaterialStatus}"/>
            <ContentControl Canvas.Top="470" Canvas.Left="370" Content="{Binding MaterialStatusList.FrontSetAssembleCvMaterialStatus}"/>
            <ContentControl Canvas.Top="470" Canvas.Left="480" Content="{Binding MaterialStatusList.FrontSetOut1CvMaterialStatus}"/>
            <ContentControl Canvas.Top="470" Canvas.Left="575" Content="{Binding MaterialStatusList.FrontSetOut2CvMaterialStatus}"/>
            <ContentControl Canvas.Top="470" Canvas.Left="670" Content="{Binding MaterialStatusList.FrontSetOut3CvMaterialStatus}"/>
            <!-- Thêm TextBlock để hiển thị đồng hồ --><!--
            <TextBlock x:Name="ClockText"
               Canvas.Top="415" Canvas.Left="230"
               FontSize="10" FontWeight="Normal" Foreground="Black"
                       Text="Clock here"/>-->
        </Canvas>

