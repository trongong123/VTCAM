        <Border Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Width="70" Height="48"
                Margin="22 -0 7 160" BorderThickness="1" BorderBrush="{StaticResource PrimaryBorderBrush}" Background="White" CornerRadius="3">
            <UniformGrid Rows="2">
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Inputs.DownstreamRearLoadEnable.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InterfaceSignalOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="I/F IN" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Outputs.DownstreamRearLoadEnable.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InterfaceSignalOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="I/F OUT" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Border Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Width="70" Height="48"
                Margin="22 -0 7 68" BorderThickness="1" BorderBrush="{StaticResource PrimaryBorderBrush}" Background="White" CornerRadius="3">
            <UniformGrid Rows="2">
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Inputs.DownstreamFrontLoadEnable.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InterfaceSignalOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="I/F IN" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Outputs.DownstreamFrontLoadEnable.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InterfaceSignalOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="I/F OUT" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Border Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Width="70" Height="48"
                Margin="7 10 3 68" BorderThickness="1" BorderBrush="{StaticResource PrimaryBorderBrush}" Background="White" CornerRadius="3">
            <UniformGrid Rows="2">
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Inputs.UpStreamFrontLoadEnable.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InterfaceSignalOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="I/F IN" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Outputs.UpstreamFrontLoadEnable.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InterfaceSignalOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="I/F OUT" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Border Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Width="70" Height="48"
                Margin="7 10 3 160" BorderThickness="1" BorderBrush="{StaticResource PrimaryBorderBrush}" Background="White" CornerRadius="3">
            <UniformGrid Rows="2">
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Inputs.UpStreamRearLoadEnable.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InterfaceSignalOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="I/F IN" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Outputs.UpstreamRearLoadEnable.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InterfaceSignalOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="I/F OUT" FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!--<Border Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left"
                Width="140" Height="60"
                Margin="22 -250 50 0" BorderThickness="1" BorderBrush="{StaticResource PrimaryBorderBrush}" Background="White" CornerRadius="3">
            <UniformGrid Rows="2">
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding Devices.Vision.IsVisionConnected, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="Vision" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Height="15" Width="15" Background="{Binding SpeedControllersIsConnected, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToOnOffBrushConverter}}" CornerRadius="2" Margin="5" />
                    <TextBlock Text="Rollers" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" Margin="5"/>
                </StackPanel>
            </UniformGrid>
        </Border>-->

        <Border Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0 5 87 0">
            <ItemsControl ItemsSource="{Binding TrayList.ListStatus}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1">
                        </UniformGrid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Height="25"
                                Margin="1"
                                MinWidth="40"
                                CornerRadius="3"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Background="{Binding Path=., Converter={StaticResource CellStatusToColorConverter}}">
                            <TextBlock HorizontalAlignment="Center"
                                        Margin="2 0"
                                       FontSize="12"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Center"
                                        Text="{Binding .,Converter={StaticResource TrayCellStatusToContentConverter}}"
                                        Foreground="Black" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
        
        <Border Grid.Column="0" Width="270" Height="320" Margin="80 40 90 40"
                VerticalAlignment="Top" HorizontalAlignment="Right" 
                 Background="White" BorderBrush="{StaticResource HighLightBorderBrush}"
                BorderThickness="1">
            <!--<Border.Effect>
                <DropShadowEffect Color="Silver"
                    Opacity="0.5"
                    BlurRadius="3"/>
            </Border.Effect>-->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <!-- TRAY CAMERA -->

                <Button FontSize="11"
                        Content="All"
                        IsEnabled="{Binding MachineStatus.IsStandByProcessMode}"
                        Command="{Binding Path=DataContext.TrayList.ResetAllCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                <ItemsControl ItemsSource="{Binding TrayList.OnOffCellButtons}"
                              Grid.Row="1"
                              IsEnabled="{Binding MachineStatus.IsStandByProcessMode}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="1"
                                         Rows="{Binding Path=TrayList.OnOffCellButtons.Count}">
                            </UniformGrid>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    CommandParameter="{Binding Index}"
                                    Command="{Binding Path=DataContext.TrayList.RowOnOffCommand, RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}"
                                    Margin="1"
                                    FontSize="10" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding TrayList.OnOffCellColumnButtons}"
                              Grid.Column="1"
                              IsEnabled="{Binding MachineStatus.IsStandByProcessMode}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"
                                         Columns="{Binding Path=TrayList.OnOffCellColumnButtons.Count}">
                            </UniformGrid>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    CommandParameter="{Binding Index}"
                                    Command="{Binding Path=DataContext.TrayList.ColumnOnOffCommand, RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}"
                                    Margin="1"
                                    FontSize="10" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl IsEnabled="{Binding MachineStatus.IsStandByProcessMode}"
                              ItemsSource="{Binding TrayList.TrayCamera.Cells}"
                              Grid.Column="1"
                              Grid.Row="1">
                    <ItemsControl.Template>
                        <ControlTemplate>
                            <!--<ItemsPresenter/>-->
                            <ItemsPresenter RenderTransformOrigin="0.5,0.5">
                                <ItemsPresenter.RenderTransform>
                                    <ScaleTransform ScaleY="-1"/>
                                </ItemsPresenter.RenderTransform>
                            </ItemsPresenter>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <control:CamTrayCellView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding DataContext.TrayList.TrayCamera.Columns, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </Border>

        <Grid Width="150" Grid.Column="1">
            <Grid.Resources>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="BorderBrush" Value="{StaticResource HighLightBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Margin" Value="1" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="3">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Silver" Opacity="0.5" BlurRadius="3"/>
                                    </Border.Effect>
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0.98"
                                                    ScaleY="0.98"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition Height="*"/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Button Command="{Binding SelectRunModeCommand}"
                    Content="{Binding MachineStatus.MachineRunModeDisplay}"
                    IsEnabled="{Binding MachineStatus.IsEnableSelectMode}"
                    Background="LightSkyBlue" />
            <Button Command="{Binding IoMonitoringCommand}"
                    Grid.Row="1"
                    Content="IO Monitor"
                    Background="LightSkyBlue" />
            <Button Command="{Binding InitializeCommand}"
                    Content="Init" 
                    Grid.Row="2"
                    IsEnabled="{Binding MachineStatus.IsStandByProcessMode}"
                    Background="LightSkyBlue" />
            <Button Command="{Binding OriginCommand}"
                    Content="Origin"
                    Grid.Row="3"
                    IsEnabled="{Binding MachineStatus.IsStandByProcessMode}"
                    Background="LightSkyBlue" />
            <Button Command="{Binding ProductInforCommand}"
                    Grid.Row="4"
                    Content="Product Info"
                    Background="PaleGreen" />
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <!--TackTime (Sec)-->
                <Button Content="T/T(Sec)" Grid.Column="0" Grid.Row="0"
                        Background="White" />
                <Button Grid.Column="1"
                        Background="White" >
                    <Button.Content>
                        <TextBlock Text="{Binding WorkData.CycleTime, Mode=OneWay, StringFormat='{}{0:0.#}'}"/>
                    </Button.Content>
                </Button>

                <!--TackTime (Avg)-->
                <!--<Button Content="T/T(Avg)" Grid.Column="0" Grid.Row="1"
                        Background="White" />
                <Button Grid.Row="1" Grid.Column="1"
                        Background="White" >
                    <Button.Content>
                        <TextBlock Text="{Binding WorkData.AverageCycleTime, Mode=OneWay, StringFormat='{}{0:0.#}'}"/>
                    </Button.Content>
                </Button> -->
            </Grid>
            <UniformGrid Columns="2"
                         Grid.Row="6">
                <Button Command="{Binding InputStopCommand}"
                        FontSize="13"
                        HorizontalContentAlignment="Center"
                        Content="INPUT&#x0A; STOP"
                        Background="{Binding MachineStatus.IsInputStop, Converter={StaticResource BoolenToBrushesStartStopButton}, ConverterParameter=InOutStop}" />
                <Button Command="{Binding OutputStopCommand}"
                        FontSize="13"
                        HorizontalContentAlignment="Center"
                        Content="OUTPUT&#x0A;  STOP"
                        Background="{Binding MachineStatus.IsOutputStop, Converter={StaticResource BoolenToBrushesStartStopButton}, ConverterParameter=InOutStop}" />
            </UniformGrid>
            <Button Command="{Binding StartCommand}"
                    Content="START" 
                    Grid.Row="7"
                    Background="{Binding MachineStatus.IsRunningProcessMode, Converter={StaticResource BoolenToBrushesStartStopButton}, ConverterParameter=Start}" />
            <Button Command="{Binding StopCommand}"
                    Content="STOP"
                    Grid.Row="8"
                    Background="{Binding MachineStatus.IsStandByProcessMode, Converter={StaticResource BoolenToBrushesStartStopButton}, ConverterParameter=Stop}"  />
        </Grid>
    </Grid>
</UserControl>
