<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.NavigateMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             d:DataContext="{d:DesignInstance Type=vm:NavigateMenuViewModel}"
             d:DesignHeight="70" d:DesignWidth="800"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style TargetType="{x:Type ui:ImageRadioButton}"
           BasedOn="{StaticResource {x:Type ui:ImageRadioButton}}">
            <Style.Setters>
                <Setter Property="Padding" Value="-1 -1 -4 -4" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style.Setters>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
            <ui:ImageRadioButton x:Name="AutoRdBtn"
                GroupName="VMNavigateButton"
                Command="{Binding AutoNavigate}"
                Image="{StaticResource image_NV_MainUI_Auto_Hover}"
                DisabledImage="{StaticResource image_NV_MainUI_Auto_Default}"/>
            <ui:ImageRadioButton x:Name="ManualRdBtn"
                GroupName="VMNavigateButton"
                Command="{Binding ManualNavigate}"
                IsEnabled="{Binding MachineStatus.IsStandByProcessMode}"
                Image="{StaticResource image_NV_MainUI_Manual_Hover}"
                DisabledImage="{StaticResource image_NV_MainUI_Manual_Default}"/>
            <ui:ImageRadioButton x:Name="TeachRdBtn"
                GroupName="VMNavigateButton"
                Command="{Binding TeachNavigate}"
                IsEnabled="{Binding MachineStatus.IsStandByProcessMode}"
                Image="{StaticResource image_NV_MainUI_Teach_Hover}"
                DisabledImage="{StaticResource image_NV_MainUI_Teach_Default}"/>
            <ui:ImageRadioButton x:Name="DataRdBtn"
                GroupName="VMNavigateButton"
                Command="{Binding DataNavigate}"
                IsEnabled="{Binding MachineStatus.IsStandByProcessMode}"
                Image="{StaticResource image_NV_MainUI_Data_Hover}"
                DisabledImage="{StaticResource image_NV_MainUI_Data_Default}"/>
        </StackPanel>

        <ui:LogDisplayer Grid.Column="1" Margin="3 3" />

        <StackPanel Orientation="Horizontal" Grid.Column="2">
            <ui:ImageRadioButton x:Name="LogRdBtn"
                GroupName="VMNavigateButton"
                Command="{Binding LogNavigate}"
                Image="{StaticResource image_NV_MainUI_Log_Hover}"
                DisabledImage="{StaticResource image_NV_MainUI_Log_Default}"/>
            <ui:ImageButton
                Background="Transparent"
                BorderBrush="Transparent"
                Padding="-1 -1 -4 -4" Margin="0"
                Command="{Binding HideCommand}"
                Image="{StaticResource image_NV_MainUI_Hide_Default}"/>
            <ui:ImageButton
                Background="Transparent"
                BorderBrush="Transparent"
                Padding="-1 -1 -4 -4" Margin="0"
                Command="{Binding ApplicationCloseCommand}"
                Image="{StaticResource image_NV_MainUI_Exit_Default}"/>
        </StackPanel>
    </Grid>
</UserControl>
