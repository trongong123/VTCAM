<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.TeachView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             xmlns:uc="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             xmlns:cvt="clr-namespace:FrontCameraAssembleEquipment.Converters"
             xmlns:converter="clr-namespace:EQX.UI.Converters;assembly=EQX.UI"
             d:DataContext="{d:DesignInstance Type=vm:TeachViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid>
        <TabControl ItemsSource="{Binding DataContext.ProcessListTeaching, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    SelectedItem="{Binding DataContext.SelectedProcess, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem"
                       BasedOn="{StaticResource {x:Type TabItem}}">
                    <Setter Property="Width"
                            Value="Auto" />
                </Style>
            </TabControl.ItemContainerStyle>

            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <UniformGrid Rows="1"
                                     IsItemsHost="True" />

                        <ContentPresenter Grid.Row="1"
                                          ContentSource="SelectedContent"
                                          Margin="3" />
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <local:UnitTeachControlView UnitImage="{Binding DataContext.UnitImageSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Cylinders="{Binding DataContext.Cylinders, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Motions="{Binding DataContext.Motions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Outputs="{Binding DataContext.Outputs, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Inputs="{Binding DataContext.Inputs, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Vaccums="{Binding DataContext.Vaccums, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SemiAutoSequences="{Binding DataContext.SemiAutoSequences, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                TeachingPositions="{Binding DataContext.TeachingPositions, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SelectedPositionGroup="{Binding DataContext.SelectedPositionGroup, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SaveTargetCommand="{Binding DataContext.SaveTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SaveCurrentCommand="{Binding DataContext.SaveCurrentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SemiAutoCommand="{Binding DataContext.SemiAutoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                StopMoveTeachingPosCommand="{Binding DataContext.StopMoveTeachingPosCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                MoveContiCommand="{Binding DataContext.MoveContiCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                JogCommand="{Binding DataContext.JogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                StopCommand="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                MoveCommand="{Binding DataContext.MoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SearchZPosCommand="{Binding DataContext.SearchZPosCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SetJogSpeedCommand="{Binding DataContext.SetJogSpeedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ZReadyMoveCommand="{Binding DataContext.ZReadyMoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                JogSpeed="{Binding DataContext.JogSpeed, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                JogInc="{Binding DataContext.JogInc, Mode=OneWayToSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsMoveJog="{Binding DataContext.IsMoveJog, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsFrontCv="{Binding DataContext.IsFrontCv, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                XCamTray="{Binding DataContext.XCamTray, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                YCamTray="{Binding DataContext.YCamTray, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                BarcodeReader="{Binding DataContext.BarcodeReader, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsTrayHeadProcess="{Binding DataContext.IsTrayHeadProcess, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsCamHeadProcess="{Binding DataContext.IsCamHeadProcess, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsCamTrayHeadProcess="{Binding DataContext.IsCamTrayHeadProcess, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsTrayHeadPickPos="{Binding DataContext.IsTrayHeadPickPos, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsZSearchPos="{Binding DataContext.IsZSearchPos, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                MotionNameList="{Binding DataContext.MotionNameList, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                MotionNameSelected="{Binding DataContext.MotionNameSelected, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                MotionSelected="{Binding DataContext.MotionSelected, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsMultipleAxisSelection="{Binding DataContext.IsMultipleAxisSelection, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IncStepList="{Binding DataContext.IncStepList, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IncStepSelected="{Binding DataContext.IncStepSelected, Mode=OneWayToSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                JogSpeedList="{Binding DataContext.JogSpeedList, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                JogSpeedIndexSelected="{Binding DataContext.JogSpeedIndexSelected,Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>
