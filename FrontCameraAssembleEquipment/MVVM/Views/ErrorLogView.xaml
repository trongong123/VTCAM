<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.ErrorLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             mc:Ignorable="d"
             x:Name="root"
             d:DataContext="{d:DesignInstance Type={x:Type vm:ErrorLogViewModel}}"
             Loaded="UserControl_Loaded"
             d:DesignHeight="600"
             d:DesignWidth="1024">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="9*" />
        </Grid.RowDefinitions>
        <Grid DockPanel.Dock="Top"
              Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="70" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Margin="5 0 0 0">
                <DatePicker SelectedDate="{Binding SearchTime, Mode=TwoWay}"
                            Height="30"
                            VerticalContentAlignment="Center"
                            Width="180"
                            VerticalAlignment="Center" />
                <Button Content="Today"
                        FontWeight="Medium"
                        Width="60"
                        Margin="5 10 5 10"
                        Command="{Binding SetSearchTimeTodayCommand}" />
                <UniformGrid Rows="1"
                             Margin="5 10">
                    <Button Content="Clear"
                            FontWeight="Medium"
                            Width="60"
                            Command="{Binding ClearLogCommand}" />
                    <Button Content="Read"
                            FontWeight="Medium"
                            Width="60"
                            Command="{Binding ReadLogCommand}" />
                </UniformGrid>
            </StackPanel>

            <UniformGrid Grid.Column="1"
                         Rows="1"
                         Margin="5">
                <RadioButton GroupName="Shift"
                             Content="All Shift"
                             FontSize="12"
                             Height="30"
                             IsChecked="{Binding IsAllShift}" />
                <RadioButton GroupName="Shift"
                             Content="Day Shift(8:00 ~ 20:00)"
                             Height="30"
                             FontSize="12"
                             IsChecked="{Binding IsDayShift}" />
                <RadioButton GroupName="Shift"
                             Content="Night Shift(20:00 ~ 8:00)"
                             Height="30"
                             FontSize="12"
                             IsChecked="{Binding IsNightShift}" />
            </UniformGrid>

            <!-- Search End Time -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Visibility="Collapsed">
                <TextBlock Text="Search End Time: "
                           FontWeight="SemiBold"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <DatePicker SelectedDate="{Binding SearchEndTime, Mode=TwoWay}"
                            Width="180"
                            Margin="0,5,0,0"
                            VerticalAlignment="Center" />
            </StackPanel>

            <Button Grid.Column="2"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Content="Detail"
                    Panel.ZIndex="1"
                    Margin="5 10"
                    FontWeight="Medium"
                    Width="60"
                    Command="{Binding DevLogCommand}" />
        </Grid>
        <StackPanel Grid.Row="1"
                    Margin="5 0 0 0"
                    Orientation="Horizontal">
            <Label Content="ClearTime"
                   FontSize="12"
                   Visibility="{Binding ClearLogSet , Converter={StaticResource BooleanToVisibilityConverter}}"
                   Margin="3 10 0 10"
                   VerticalAlignment="Center" />
            <Label Content="{Binding ClearTime}"
                   FontSize="12"
                   Visibility="{Binding ClearLogSet , Converter={StaticResource BooleanToVisibilityConverter}}"
                   BorderBrush="Gray"
                   BorderThickness="1"
                   Margin="3 10 0 10"
                   VerticalAlignment="Center" />
        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="ErrorListHistoryDataGrid"
                      Margin="5"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      SelectionUnit="CellOrRowHeader"
                      SelectionMode="Extended"
                      ClipboardCopyMode="ExcludeHeader"
                      CanUserAddRows="False"
                      Sorting="ErrorListHistoryDataGrid_Sorting"
                      ItemsSource="{Binding ErrorListEntry}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHightlight}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="Yellow" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="TextCollumnErrorData"
                                        Header="DateTime"
                                        IsReadOnly="True"
                                        SortDirection="Descending"
                                        Binding="{Binding Timestamp}"
                                        SortMemberPath="Timestamp"
                                        Width="90" />
                    <DataGridTextColumn Header="ErrorCode"
                                        IsReadOnly="True"
                                        Binding="{Binding ErrorCode}"
                                        Width="80" />
                    <DataGridTextColumn Header="Message"
                                        IsReadOnly="True"
                                        Binding="{Binding Message}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping"
                                        Value="Wrap" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>

            </DataGrid>

            <DataGrid Grid.Column="2"
                      Margin="5"
                      x:Name="ErrorCountHistoryDataGrid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectedItem="{Binding ErrorLogCountSelected}"
                      ItemsSource="{Binding ErrorLogCount}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Count"
                                        IsReadOnly="True"
                                        Binding="{Binding Count}"
                                        Width="50" />
                    <DataGridTextColumn Header="ErrorCode"
                                        IsReadOnly="True"
                                        Binding="{Binding ErrorCode}"
                                        Width="80" />
                    <DataGridTextColumn Header="Message"
                                        IsReadOnly="True"
                                        Binding="{Binding Message}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping"
                                        Value="Wrap" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
