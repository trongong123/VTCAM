<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.ManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
             xmlns:uc="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             xmlns:cvt="clr-namespace:FrontCameraAssembleEquipment.Converters"
             xmlns:converter="clr-namespace:EQX.UI.Converters;assembly=EQX.UI"
             d:DataContext="{d:DesignInstance Type=vm:ManualViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <TabControl ItemsSource="{Binding MaintenanceViewModels}"
                    SelectedIndex="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem"
                       BasedOn="{StaticResource {x:Type TabItem}}">
                    <Setter Property="Width"
                            Value="Auto" />
                    <Setter Property="Header"
                            Value="{Binding Name}"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <UniformGrid Rows="1"
                                     IsItemsHost="True" />

                        <ContentPresenter Grid.Row="1"
                                          ContentSource="SelectedContent"
                                          Margin="3" />
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
        </TabControl>
    </Grid>
</UserControl>
