<UserControl x:Class="FrontCameraAssembleEquipment.MVVM.Views.CVManualControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:views="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
             xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
             xmlns:cvt="clr-namespace:FrontCameraAssembleEquipment.Converters"
             xmlns:control="clr-namespace:FrontCameraAssembleEquipment.Resources.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border CornerRadius="5"
                               BorderBrush="#DDD"
                               BorderThickness="1"
                               Background="White"
                               SnapsToDevicePixels="True">
                            <DockPanel>
                                <Border Background="#E1E1E2"
                                       DockPanel.Dock="Top"
                                       Padding="8,4"
                                       CornerRadius="5,5,0,0">
                                    <TextBlock Text="{TemplateBinding Header}"
                                              FontWeight="Bold"
                                              Foreground="Black"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              FontSize="13" />
                                </Border>

                                <ContentPresenter/>
                            </DockPanel>
                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Grid.ColumnSpan="3" Grid.Column="0" Header="REAR">
            <UniformGrid Columns="4">
                <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="1">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Label Content="INPUT CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ContentControl Content="{Binding RearCVsInCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"/>
                        <Label Content="MANUAL CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ContentControl Content="{Binding RearManualInCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="DETACH CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding RearCVsDetachCv,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel  HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding RearCylindersDetachCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="ASSEMBLE CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding RearCVsAssembleCv,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel  HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding RearCylindersAssembleCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="OUTPUT CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding RearCVsOutCv,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel  HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding RearCylindersOutCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </GroupBox>

        
        <!--FRONT CV-->
        <GroupBox Grid.Row="1" Grid.ColumnSpan="3" Grid.Column="0" Header="FRONT">
            <UniformGrid Columns="4">
                <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="1">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Label Content="INPUT CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ContentControl Content="{Binding CVsInCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"/>
                        <Label Content="MANUAL CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ContentControl Content="{Binding ManualInCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="DETACH CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding CVsDetachCv,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel  HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CylindersDetachCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="ASSEMBLE CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding CVsAssembleCv,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel  HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CylindersAssembleCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border BorderBrush="Gray" CornerRadius="5" BorderThickness="1" Margin="1">
                    <StackPanel Orientation="Vertical">
                        <Label Content="OUTPUT CV" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding CVsOutCv,RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}"
                                      ItemTemplate="{StaticResource ConveyorControlTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel  HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CylindersOutCv, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </GroupBox>

    </Grid>
</UserControl>
