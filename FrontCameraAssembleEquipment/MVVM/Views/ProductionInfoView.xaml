<Window x:Class="FrontCameraAssembleEquipment.MVVM.Views.ProductionInfoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrontCameraAssembleEquipment.MVVM.Views"
        xmlns:vm="clr-namespace:FrontCameraAssembleEquipment.MVVM.ViewModels"
        mc:Ignorable="d"
        xmlns:ui="clr-namespace:EQX.UI.Controls;assembly=EQX.UI"
        WindowStyle="None"
        d:DataContext="{d:DesignInstance Type={x:Type vm:ProductionInfoViewModel}}"
        Title="ProductionInfoView"
        Height="600"
        Width="900">

    <Window.Resources>
        <Style TargetType="{x:Type ui:ImageButton}"
               BasedOn="{StaticResource {x:Type ui:ImageButton}}">
            <Style.Setters>
                <Setter Property="Padding"
                        Value="5 10" />
                <Setter Property="Margin"
                        Value="2" />
                <Setter Property="Height"
                        Value="50" />
                <Setter Property="Width"
                        Value="105" />
                <Setter Property="FontSize"
                        Value="13" />
            </Style.Setters>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#C0C0C0"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- Header -->
            <Border Background="#E8E8E8"
                    Height="50"
                    BorderBrush="Gray"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <TextBlock x:Name="ClockText"
                               Text="Product Info"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="10,0,0,0" />
                    <ui:ImageButton Content="Exit"
                                    Height="40"
                                    Margin="0 0 10 0"
                                    Width="150"
                                    HorizontalAlignment="Right"
                                    Image="{StaticResource image_exit_selected}"
                                    Click="ExitButton_Click" />
                </Grid>
            </Border>

            <!-- Search Times -->
            <Grid Grid.Row="1"
                  Margin="0,20,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.3*" />
                </Grid.ColumnDefinitions>

                <!-- Search Start Time -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="5 0 0 0 ">
                    <DatePicker SelectedDate="{Binding SearchTime, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Height="30"
                                Width="120"
                                Margin="5 5 0 0" />
                    <Button Content="Today"
                            FontWeight="Medium"
                            Width="120"
                            Margin="5,5,0,0"
                            Command="{Binding SetSearchTimeTodayCommand}" />
                    <Label Content="{Binding Today}"
                           Visibility="Collapsed"
                           BorderBrush="Gray"
                           BorderThickness="1"
                           Margin="3 4.5 0 0"
                           VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <UniformGrid Rows="1"
                                 Margin="10 0">
                        <RadioButton GroupName="Shift"
                                     Content="All Shift"
                                     Padding="8"
                                     Height="30"
                                     Margin="0 4 0 0"
                                     IsChecked="{Binding IsAllShift,Mode=OneWay}"
                                     Command="{Binding AllShiftCommand}" />
                        <RadioButton GroupName="Shift"
                                     Content="Day Shift (8:00 ~ 20:00)"
                                     Padding="8"
                                     Height="30"
                                     Margin="0 4 0 0"
                                     IsChecked="{Binding IsDayShift,Mode=OneWay}"
                                     Command="{Binding DayShiftCommand}" />
                        <RadioButton GroupName="Shift"
                                     Content="Night Shift (20:00 ~ 8:00)"
                                     Height="30"
                                     Margin="0 4 0 0"
                                     IsChecked="{Binding IsNightShift,Mode=OneWay}"
                                     Command="{Binding NightShiftCommand}" />
                    </UniformGrid>
                </StackPanel>
                <!-- Searchnd Time -->
                <!--<StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="SEARCH END TIME"
                               FontWeight="Bold"
                               FontSize="14"
                               HorizontalAlignment="Center"/>
                    <DatePicker SelectedDate="{Binding SearchEndTime, Mode=TwoWay}"
                                Width="180" Margin="0,5,0,0"/>
                </StackPanel>-->
            </Grid>
            <Grid Grid.Row="2"
                  Visibility="{Binding IsAllShift,Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.8*" />
                    <RowDefinition Height="1.3*" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0"
                      Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#B0B0B0"
                            BorderThickness="1 1 1 0">
                        <TextBlock Text="Count Data"
                                   Margin="0 0 0 1"
                                   Background="LightGray"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Padding="4"
                                   TextAlignment="Center"
                                   VerticalAlignment="Top" />

                    </Border>
                    <Border Margin="0 30 0 0"
                            BorderBrush="#B0B0B0"
                            BorderThickness="1 0 1 1">
                        <Border.Resources>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                                <Setter Property="FontSize"
                                        Value="15" />
                                <Setter Property="VerticalAlignment"
                                        Value="Center" />
                                <Setter Property="TextAlignment"
                                        Value="Center" />
                            </Style>
                        </Border.Resources>
                        <UniformGrid Columns="1">
                            <TextBlock Text="Total"
                                       Margin="0 10" />
                            <TextBlock Text="Rear CV"
                                       Margin="0 10" />
                            <TextBlock Text="Front CV"
                                       Margin="0 10" />
                        </UniformGrid>
                    </Border>
                    <UniformGrid Grid.Column="2"
                                 Columns="4">
                        <UniformGrid.Resources>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                                <Setter Property="FontSize"
                                        Value="15" />
                                <Setter Property="VerticalAlignment"
                                        Value="Center" />
                                <Setter Property="TextAlignment"
                                        Value="Center" />
                            </Style>
                        </UniformGrid.Resources>
                        <Border BorderBrush="#B0B0B0"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Border BorderBrush="#B0B0B0"
                                        BorderThickness="0 0 0.5 0">
                                    <TextBlock Text="INPUT"
                                               VerticalAlignment="Top"
                                               Background="LightGray"
                                               Padding="4" />
                                </Border>

                                <UniformGrid Columns="1"
                                             Grid.Row="1">
                                    <TextBlock Text="{Binding ProductionDay.TotalOutput}"
                                               Margin="0 10" />
                                    <TextBlock Text="{Binding ProductionDay.TotalRearOutput}"
                                               Margin="0 10" />
                                    <TextBlock Text="{Binding ProductionDay.TotalFrontOutput}"
                                               Margin="0 10" />

                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Border BorderBrush="#B0B0B0"
