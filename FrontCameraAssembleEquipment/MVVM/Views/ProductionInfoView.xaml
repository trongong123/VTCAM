                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Border BorderBrush="#B0B0B0"
                                        BorderThickness="0.5 0 0 0">
                                    <TextBlock Text="OK"
                                               VerticalAlignment="Top"
                                               Background="LightGray"
                                               Padding="4" />
                                </Border>
                                <UniformGrid Columns="1"
                                             Grid.Row="1">
                                    <TextBlock Text="{Binding ProductionDay.TotalPass}"
                                               Margin="0 10" />
                                    <TextBlock Text="{Binding ProductionDay.TotalRearPass}"
                                               Margin="0 10" />
                                    <TextBlock Text="{Binding ProductionDay.TotalFrontPass}"
                                               Margin="0 10" />

                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Border BorderBrush="#B0B0B0"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Border BorderBrush="#B0B0B0"
                                        BorderThickness="0 0 0.5 0">
                                    <TextBlock Text="NG"
                                               VerticalAlignment="Top"
                                               Background="LightGray"
                                               Padding="4" />
                                </Border>
                                <UniformGrid Columns="1"
                                             Grid.Row="1">
                                    <TextBlock Text="{Binding ProductionDay.TotalFail}"
                                               Margin="0 10" />
                                    <TextBlock Text="{Binding ProductionDay.TotalRearFail}"
                                               Margin="0 10" />
                                    <TextBlock Text="{Binding ProductionDay.TotalFrontFail}"
                                               Margin="0 10" />

                                </UniformGrid>
                            </Grid>
