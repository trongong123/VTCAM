<UserControl x:Class="EQX.UI.Controls.CylinderSimpleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EQX.UI.Controls"
             mc:Ignorable="d"
             xmlns:cvt="clr-namespace:EQX.UI.Converters"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>
        <cvt:AddSpacesToSentenceConverter x:Key="AddSpacesToSentenceConverter" />
        <cvt:CylinderSimpleViewCylinderTypeToButtonNameConverter x:Key="CylinderSimpleViewCylinderTypeToButtonNameConverter" />
        <Style x:Key="ForwardMovingButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="BorderBrush"
                    Value="{StaticResource PrimaryBorderBrush}" />
            <Setter Property="Background"
                    Value="{Binding IsForward, Converter={StaticResource BooleanToHighLightBrushConverter}}" />
            <Setter Property="Opacity"
                    Value="1" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsOutForward}"
                                   Value="True" />
                        <Condition Binding="{Binding IsForward}"
                                   Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background"
                            Value="#FFFFEB3B" />
                    <Setter Property="BorderBrush"
                            Value="#FFF9A825" />
                    <Setter Property="Foreground"
                            Value="Black" />
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="ForwardMovingStoryboard">
                            <Storyboard RepeatBehavior="Forever"
                                        AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1"
                                                 To="0.45"
                                                 Duration="0:0:0.35" />
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="ForwardMovingStoryboard" />
                    </MultiDataTrigger.ExitActions>
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsForwardInterlock}"
                             Value="True">
                    <Setter Property="Background"
                            Value="Black" />
                    <Setter Property="Foreground"
                            Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BackwardMovingButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="BorderBrush"
                    Value="{StaticResource PrimaryBorderBrush}" />
            <Setter Property="Background"
                    Value="{Binding IsBackward, Converter={StaticResource BooleanToHighLightBrushConverter}}" />
            <Setter Property="Opacity"
                    Value="1" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsOutBackward}"
                                   Value="True" />
                        <Condition Binding="{Binding IsBackward}"
                                   Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background"
                            Value="#FFFFEB3B" />
                    <Setter Property="BorderBrush"
                            Value="#FFF9A825" />
                    <Setter Property="Foreground"
                            Value="Black" />
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard x:Name="BackwardMovingStoryboard">
                            <Storyboard RepeatBehavior="Forever"
                                        AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1"
                                                 To="0.45"
                                                 Duration="0:0:0.35" />
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="BackwardMovingStoryboard" />
                    </MultiDataTrigger.ExitActions>
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding IsBackwardInterlock}"
                             Value="True">
                    <Setter Property="Background"
                            Value="Black" />
                    <Setter Property="Foreground"
                            Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="Gray"
            CornerRadius="5"
            BorderThickness="1"
            Margin="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding Name}"
                       FontWeight="Bold"
                       TextAlignment="Center" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Click="ForwardButtonClick"
                        d:Content="Forward"
                        Style="{StaticResource ForwardMovingButtonStyle}"
                        Content="{Binding CylinderType, Converter={StaticResource CylinderSimpleViewCylinderTypeToButtonNameConverter}, ConverterParameter=true}">
                </Button>
                <Separator Width="35"
                           Height="1"
                           Grid.Column="1"
                           Margin="3 0">
                    <Separator.LayoutTransform>
                        <RotateTransform Angle="90" />
                    </Separator.LayoutTransform>
                </Separator>
                <Button Grid.Column="2"
                        Click="BackwardButtonClick"
                        d:Content="Backward"
                        Style="{StaticResource BackwardMovingButtonStyle}"
                        Content="{Binding CylinderType, Converter={StaticResource CylinderSimpleViewCylinderTypeToButtonNameConverter}, ConverterParameter=false}">
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
