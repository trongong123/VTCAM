<UserControl x:Class="EQX.UI.Controls.DOutputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EQX.UI.Controls"
             xmlns:inout="clr-namespace:EQX.Core.InOut;assembly=EQX.Core"
             xmlns:cvt="clr-namespace:EQX.UI.Converters"
             mc:Ignorable="d"
             d:Width="150"
             d:DataContext="{d:DesignInstance Type=inout:IDOutput}"
             Height="Auto">

    <UserControl.Resources>
        <cvt:InOutStatusToOnOffBrushConverter x:Key="InOutStatusToOnOffBrushConverter"/>
        <cvt:BooleanToOnOffBrushConverter x:Key="BooleanToOnOffBrushConverter"/>
        <cvt:DisableSpareInOutConverter x:Key="DisableSpareInOutConverter"/>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=Name,
                Converter={StaticResource DisableSpareInOutConverter}}"
                         Value="true">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="Opacity" Value="0.4"/>
                </DataTrigger>
            </Style.Triggers>
            <Setter Property="Background" Value="GhostWhite"/>
        </Style>
    </UserControl.Style>

    <Button Style="{StaticResource ContentOnlyButtonStyle}"
            Padding="0"
            Click="Button_Click">
        <Border BorderThickness="1"
                BorderBrush="Black"
                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="3">
            <Border.Effect>
                <DropShadowEffect Color="Silver"
                      Opacity="0.5"
                      BlurRadius="3"/>
            </Border.Effect>
            <Grid Margin="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Ellipse
                    Width="25"
                    Grid.RowSpan="2"
                    Height="25"
                    Margin="3 0 0 0"
                    Stroke="LightGray"
                    d:Fill="Tomato"
                         >
                    <Ellipse.Fill>
                        <MultiBinding Converter="{StaticResource InOutStatusToOnOffBrushConverter}">
                            <Binding Path="DataContext.Value" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=UserControl}"/>
                            <Binding Path="DataContext.Name" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=UserControl}"/>
                        </MultiBinding>
                    </Ellipse.Fill>
                </Ellipse>

                <TextBlock Text="{Binding Id, StringFormat=[Y{0}]}"
                           d:Text="[Y1]"
                           Margin="3 0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Grid.Column="1"/>

                <Viewbox Stretch="Fill" StretchDirection="DownOnly"
                         HorizontalAlignment="Left"
                         Margin="3 0"
                         Grid.Row="1"
                         Grid.Column="1">
                    <TextBlock Text="{Binding Name}"
                           d:Text="START_LED"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                </Viewbox>

            </Grid>
        </Border>
    </Button>
</UserControl>
