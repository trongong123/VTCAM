<UserControl x:Class="EQX.UI.Controls.JogControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             x:Name="root"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">
    <UserControl.Resources>
        <Style TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}"
               x:Key="JogButton">
            <Setter Property="Margin" Value="0 3"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <GroupBox
            Header="Jog Move" Style="{x:Null}"
            Grid.IsSharedSizeScope="True"
            >
            <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=root}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- DataContext ở đây là một đối tượng PositionPoint -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MaintenanceJogLabelWidth"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Nút Jog - -->
                            <Button Grid.Column="0" Content="-" Style="{StaticResource JogButton}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding DataContext.JogNegativeStartCommand, ElementName=root}"
                                                   CommandParameter="{Binding Motion}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseUp">
                                        <i:InvokeCommandAction Command="{Binding DataContext.JogStopCommand, ElementName=root}"
                                                   CommandParameter="{Binding Motion}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>

                            <!-- Tên trục -->
                            <TextBlock
                                Grid.Column="1" Text="{Binding Motion.Name}" Margin="2 0"
                                VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>

                            <!-- Nút Jog + -->
                            <Button Grid.Column="2" Content="+" Style="{StaticResource JogButton}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding DataContext.JogPositiveStartCommand, ElementName=root}"
                                                   CommandParameter="{Binding Motion}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseUp">
                                        <i:InvokeCommandAction Command="{Binding DataContext.JogStopCommand, ElementName=root}"
                                                   CommandParameter="{Binding Motion}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </GroupBox>
        <GroupBox
            Header="Jog Speed" FontWeight="Bold"
            Style="{x:Null}"
            Grid.Column="1"
            >
            <ListBox ItemsSource="{Binding JogSpeedItemsSource, ElementName=root}"
                     SelectedItem="{Binding SelectedJogSpeed, ElementName=root, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <!-- This ToggleButton acts as the button for each speed level -->
                                    <ToggleButton Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Style="{StaticResource {x:Type ToggleButton}}"
                                                  Margin="0 3"
                                                  Height="30"
                                                  FontWeight="Bold"
                                                  FontSize="14"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- The DataContext here is a JogSpeedLevel object -->
                        <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
</UserControl>