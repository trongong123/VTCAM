<UserControl x:Class="EQX.UI.MVVM.TeachPositionUnitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EQX.UI.MVVM"
             mc:Ignorable="d"
             Unloaded="TeachPositionUnitView_Unloaded"
             Loaded="TeachPositionUnitView_Loaded"
             xmlns:uiControls="clr-namespace:EQX.UI.Controls"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.4*"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border CornerRadius="5"
                    Margin="5"
                    BorderBrush="LightGray"
                    BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="5">
                        <StackPanel x:Name="PositionTeaching_StackPanel">
                        </StackPanel>
                    </ScrollViewer>
                    <uiControls:ImageButton Grid.Row="1"
                                            Content="Save"
                                            Command="{Binding SaveRecipeCommand}"
                                            HorizontalAlignment="Center"
                                            Width="150"
                                            Margin="0 0 0 3" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    CornerRadius="5"
                    Margin="5"
                    BorderBrush="LightGray"
                    BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <UniformGrid Rows="1"
                                 Margin="5"
                                Grid.ColumnSpan="3"
                                VerticalAlignment="Center">
                        <RadioButton Content="Jog"
                                     IsChecked="{Binding IsMoveJogMode}"
                                     GroupName="MOTION_MODE"
                                     Height="40">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton"
                                       BasedOn="{StaticResource ButtonLikeRadioButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMoveJogMode}"
                                                     Value="True">
                                            <Setter Property="IsChecked"
                                                    Value="True" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                        <RadioButton Content="Inc"
                                     GroupName="MOTION_MODE">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton"
                                       BasedOn="{StaticResource ButtonLikeRadioButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMoveJogMode}"
                                                     Value="False">
                                            <Setter Property="IsChecked"
                                                    Value="True" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                        </RadioButton>
                    </UniformGrid>
                    <Grid Grid.Row="1"
                                Margin="0 0 5 0"
                                Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Label Content="INC STEP :"
                               HorizontalContentAlignment="Left"
                               FontWeight="SemiBold"
                               VerticalContentAlignment="Center"
                               Height="40"
                               FontSize="14"
                               Margin="5 0" />
                        <ComboBox Grid.Column="1"
                                  FontSize="14"
                                  SelectedIndex="0"
                                  Height="40"
                                  ItemsSource="{Binding IncStepList}"
                                  SelectedItem="{Binding IncStepSelected, Mode=TwoWay}" />
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMoveJogMode}"
                                                 Value="True">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                    </Grid>
                    <Grid Grid.ColumnSpan="3"
                          Margin="0 0 5 0"
                          Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Label Content="JOG SPEED : "
                               VerticalContentAlignment="Center"
                               HorizontalContentAlignment="Left"
                               FontWeight="SemiBold"
                               Height="40"
                               FontSize="14"
                               Margin="5 0" />
                        <ComboBox Grid.Column="1"
                                  FontSize="14"
                                  Height="40"
                                  ItemsSource="{Binding JogSpeedList}"
                                  SelectedIndex="{Binding JogSpeedIndexSelected, Mode=TwoWay}" />
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMoveJogMode}"
                                                 Value="False">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                    </Grid>
                    <TextBox Grid.Row="2"
                             FontSize="16"
                             IsReadOnly="True"
                             Margin="0 0 5 0"
                             Text="{Binding XAxis.Status.ActualPosition,Mode=OneWay, StringFormat='{}{0:0.###} mm'}"
                             Tag="X Axis Cur Pos"
                             Grid.ColumnSpan="3">
                        <TextBox.Style>
                            <Style TargetType="TextBox"
                                   BasedOn="{StaticResource TextBoxWithDescriptionStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding XAxis}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBox Grid.Row="3"
                             FontSize="16"
                             Margin="0 0 5 0"
                             IsReadOnly="True"
                             Text="{Binding YAxis.Status.ActualPosition,Mode=OneWay, StringFormat='{}{0:0.###} mm'}"
                             Tag="Y Axis Cur Pos"
                             Grid.ColumnSpan="3">
                        <TextBox.Style>
                            <Style TargetType="TextBox"
                                   BasedOn="{StaticResource TextBoxWithDescriptionStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding YAxis}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBox Grid.Row="3"
                             FontSize="16"
                             Margin="0 0 5 0"
                             IsReadOnly="True"
                             Text="{Binding ZAxis.Status.ActualPosition,Mode=OneWay, StringFormat='{}{0:0.###} mm'}"
                             Tag="Z Axis Cur Pos"
                             Grid.ColumnSpan="3">
                        <TextBox.Style>
                            <Style TargetType="TextBox"
                                   BasedOn="{StaticResource TextBoxWithDescriptionStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ZAxis}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Grid.Row="5"
                            Tag="Minus"
                            DataContext="{Binding DataContext.XAxis,Mode=OneWay,RelativeSource={RelativeSource AncestorType=UserControl}}"
                            PreviewMouseLeftButtonUp="MoveButton_MouseUp"
                            PreviewMouseLeftButtonDown="MoveButton_MouseDown"
                            Content="X -">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.XAxis,Mode=OneWay,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Row="5"
                            Grid.Column="2"
                            Tag="Plus"
                            DataContext="{Binding DataContext.XAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                            PreviewMouseLeftButtonUp="MoveButton_MouseUp"
                            PreviewMouseLeftButtonDown="MoveButton_MouseDown"
                            Content="X +">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.XAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Row="6"
                            Grid.Column="1"
                            Tag="Minus"
                            DataContext="{Binding DataContext.ZAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                            PreviewMouseLeftButtonUp="MoveButton_MouseUp"
                            PreviewMouseLeftButtonDown="MoveButton_MouseDown"
                            Content="Z -">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ZAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Row="4"
                            Grid.Column="1"
                            Tag="Plus"
                            DataContext="{Binding DataContext.ZAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                            PreviewMouseLeftButtonUp="MoveButton_MouseUp"
                            PreviewMouseLeftButtonDown="MoveButton_MouseDown"
                            Content="Z +">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ZAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Row="6"
                            Grid.Column="1"
                            Tag="Minus"
                            DataContext="{Binding DataContext.YAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                            PreviewMouseLeftButtonUp="MoveButton_MouseUp"
                            PreviewMouseLeftButtonDown="MoveButton_MouseDown"
                            Content="Y -">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.YAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Row="4"
                            Grid.Column="1"
                            Tag="Plus"
                            DataContext="{Binding DataContext.YAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                            PreviewMouseLeftButtonUp="MoveButton_MouseUp"
                            PreviewMouseLeftButtonDown="MoveButton_MouseDown"
                            Content="Y +">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource ActionButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.YAxis,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
