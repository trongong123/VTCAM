<UserControl x:Class="EQX.UI.MVVM.PCInformationsystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:EQX.UI.Converters"
             xmlns:vm="clr-namespace:EQX.UI.MVVM"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type={x:Type vm:PCInformationsystemViewModel}}"
             d:DesignHeight="200"
             d:DesignWidth="100">
    <UserControl.Resources>
        <conv:UsagePercentToBrushConverter x:Key="UsagePercentToBrushConverter" />
    </UserControl.Resources>

    <GroupBox Header="INFORMATION SYSTEM" 
              FontSize="12"
              FontWeight="Bold"
              Style="{x:Null}">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
            Background="Transparent"
            Padding="5 0 0 0">
                <StackPanel >
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="CPU"
                           Foreground="Black"
                           FontSize="10"
                           FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuText}"
                           Foreground="Black"
                           FontWeight="Bold"
                           Margin="10 0 0 0"
                           FontSize="10"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding CpuPercent}"
                         Foreground="{Binding CpuPercent, Converter={StaticResource UsagePercentToBrushConverter}}"
                         Maximum="100"
                         Height="10"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
            Background="Transparent"
            Padding="5 0 0 0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="RAM"
                           Foreground="Black"
                           FontSize="10"
                           FontWeight="Bold"/>
                        <TextBlock Text="{Binding RamText}"
                           Margin="10 0 0 0"
                           FontWeight="Bold"
                           Foreground="Black"
                           FontSize="10"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding RamPercent}"
                         Foreground="{Binding RamPercent, Converter={StaticResource UsagePercentToBrushConverter}}"
                         Maximum="100"
                         Height="10"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
            Background="Transparent"
            Padding="5 0 0 0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="GPU"
                           Foreground="Black"
                           FontSize="10"
                           FontWeight="Bold"/>
                        <TextBlock Text="{Binding GpuText}"
                           Margin="10 0 0 0"
                           FontWeight="Bold"
                           Foreground="Black"
                           FontSize="10"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding GpuPercent}"
                         Foreground="{Binding GpuPercent, Converter={StaticResource UsagePercentToBrushConverter}}"
                         Maximum="100"
                         Height="10"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="3"
            Background="Transparent"
            Padding="5 0 0 0">
                <StackPanel>
                    <TextBlock Text="Disk Usage"
                       Foreground="Black"
                       FontSize="10"
                       FontWeight="Bold"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Disks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent"
                                    Padding="10 0 0 0">
                                        <StackPanel>
                                            <TextBlock Foreground="Black"
                                               FontSize="10">
                                        <Run Text="{Binding DriveName}"/>
                                        <Run Text="   "/>
                                        <Run Text="{Binding FreeGB, StringFormat={}{0:F0}}"/>
                                        <Run Text=" GB free / "/>
                                        <Run Text="{Binding TotalGB, StringFormat={}{0:F0}}"/>
                                        <Run Text=" GB"/>
                                            </TextBlock>
                                            <ProgressBar Value="{Binding UsedPercent}"
                                                 Foreground="{Binding UsedPercent, Converter={StaticResource UsagePercentToBrushConverter}}"
                                                 Maximum="100"
                                                 Height="10"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </GroupBox>
</UserControl>
