<UserControl x:Class="EQX.UI.MVVM.MotionsStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EQX.UI.MVVM"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid Margin="10">
        <DockPanel Grid.Row="0"
                   Grid.Column="1">
            <TextBlock Text="SERVO STATUS"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#273c75"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       DockPanel.Dock="Top" />
            <DataGrid ItemsSource="{Binding AllMotions}"
                      x:Name="MotionDataGrid"
                      Style="{StaticResource DataViewDataGridStyle}"
                      Background="White"
                      AlternatingRowBackground="#f0f2f5"
                      RowBackground="White"
                      BorderBrush="#dcdde1"
                      GridLinesVisibility="None"
                      RowHeight="36"
                      FontSize="15"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader"
                           BasedOn="{StaticResource DataViewColumnHeaderRightStyle}">
                        <Setter Property="HorizontalContentAlignment"
                                Value="Center" />
                        <Setter Property="Background"
                                Value="#718093" />
                        <Setter Property="Foreground"
                                Value="White" />
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                        <Setter Property="FontSize"
                                Value="14" />
                        <Setter Property="Padding"
                                Value="6,4" />
                        <Setter Property="BorderThickness"
                                Value="0" />
                    </Style>
                    <Style TargetType="DataGridCell"
                           BasedOn="{StaticResource DataViewDataGridCellStyle}">
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Setter Property="Padding"
                                Value="4,0,4,0" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Center" />
                        <Setter Property="VerticalContentAlignment"
                                Value="Center" />
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Axis Name"
                                        Binding="{Binding Name}"
                                        Width="2*"
                                        IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource DataViewAxisNameStyle}">
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Actual Position"
                                        Binding="{Binding Status.ActualPosition, StringFormat={}{0:0.000}}"
                                        Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource DataViewAxisNameStyle}">
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Cmd Position"
                                        Binding="{Binding Status.CommandPosition, StringFormat={}{0:0.000}}"
                                        Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource DataViewAxisNameStyle}">
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Position Error"
                                        Binding="{Binding Status.PositionError, StringFormat={}{0:0.000}}"
                                        Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"
                                   BasedOn="{StaticResource DataViewAxisNameStyle}">
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Servo On"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="20"
                                         Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"
                                                    Value="LightGray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsMotionOn}"
                                                             Value="True">
                                                    <Setter Property="Fill"
                                                            Value="Green" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Limit-"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="20"
                                         Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"
                                                    Value="LightGray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.HwNegLimitDetect}"
                                                             Value="True">
                                                    <Setter Property="Fill"
                                                            Value="OrangeRed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Home"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="20"
                                         Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"
                                                    Value="LightGray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsHomeDone}"
                                                             Value="True">
                                                    <Setter Property="Fill"
                                                            Value="Green" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Limit+"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="20"
                                         Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"
                                                    Value="LightGray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.HwPosLimitDetect}"
                                                             Value="True">
                                                    <Setter Property="Fill"
                                                            Value="OrangeRed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn  Header="Alarm"
                                             Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="20"
                                         Height="20"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"
                                                    Value="LightGray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status.IsAlarm}"
                                                             Value="True">
                                                    <Setter Property="Fill"
                                                            Value="OrangeRed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
